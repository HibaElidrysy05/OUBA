<%- include('partials/header', { title: 'Admin Panel - Ouba', activeNav: 'admin' }) %>
<div class="container" style="padding: 20px; max-width: 1000px; margin: 0 auto;">
  <div class="card">
    <div class="card-header">
      <h2><i class="fas fa-shield-alt"></i> Admin Panel</h2>
    </div>
    <div class="card-body">
      <% if (error) { %><div class="alert alert-error"><%= error %></div><% } %>
      <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <div style="overflow-x:auto">
        <table style="width:100%;border-collapse:collapse">
          <thead>
            <tr style="background:var(--pink-lighter)">
              <th style="padding:10px;text-align:left">Username</th>
              <th style="padding:10px;text-align:left">Email</th>
              <th style="padding:10px;text-align:left">Display Name</th>
              <th style="padding:10px;text-align:left">Role</th>
              <th style="padding:10px;text-align:left">Joined</th>
              <th style="padding:10px;text-align:center">Actions</th>
            </tr>
          </thead>
          <tbody>
            <% users.forEach(function(u) { %>
              <tr style="border-bottom:1px solid var(--pink-light)">
                <td style="padding:10px">@<%= u.username %></td>
                <td style="padding:10px"><%= u.email %></td>
                <td style="padding:10px"><%= u.displayName || '-' %></td>
                <td style="padding:10px">
                  <% if (u.id === user.id) { %>
                    <span class="badge badge-admin"><%= u.role %></span>
                  <% } else { %>
                    <select class="role-select" data-user-id="<%= u.id %>" style="padding:4px 8px;border-radius:8px;border:1px solid var(--pink-light);font-size:13px">
                      <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>user</option>
                      <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>admin</option>
                    </select>
                  <% } %>
                </td>
                <td style="padding:10px;font-size:13px;color:var(--text-light)"><%= new Date(u.createdAt).toLocaleDateString() %></td>
                <td style="padding:10px;text-align:center">
                  <% if (u.id !== user.id) { %>
                    <button class="btn btn-sm btn-danger" onclick="deleteUser('<%= u.id %>')" style="background:#e74c3c;color:white;border:none;padding:6px 12px;border-radius:8px;cursor:pointer;font-size:12px"><i class="fas fa-trash"></i></button>
                  <% } else { %>
                    <span style="font-size:12px;color:var(--text-light)">You</span>
                  <% } %>
                </td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      </div>
    </div>
  </div>

  <div class="card" style="margin-top:24px">
    <div class="card-header">
      <h2><i class="fas fa-toggle-on"></i> Feature Flags</h2>
    </div>
    <div class="card-body">
      <div class="flag-list">
        <div class="flag-item">
          <div class="flag-info">
            <strong>Audio Recording</strong>
            <span class="flag-desc">Allow users to record and send voice messages</span>
          </div>
          <label class="toggle-switch">
            <input type="checkbox" class="flag-toggle" data-key="audio_recording" <%= flags['audio_recording'] !== false ? 'checked' : '' %>>
            <span class="toggle-track"></span>
          </label>
        </div>
      </div>
    </div>
  </div>

  <div class="card" style="margin-top:24px">
    <div class="card-header" onclick="toggleCard(this)" style="cursor:pointer">
      <h2><i class="fas fa-bug"></i> Push Debug</h2>
      <span style="font-size:12px;color:var(--text-light)">tap to toggle</span>
    </div>
    <div class="card-body" id="pushDebugSection" style="display:none">
      <div id="pushDebugContent"></div>
      <button onclick="runDebug()" class="btn btn-sm" style="margin-top:8px">Run Checks</button>
      <button onclick="sendTestPush()" class="btn btn-sm" style="margin-top:8px;margin-left:4px">Test Push</button>
      <pre id="debugResult" style="margin-top:12px;background:#f5f5f5;padding:12px;border-radius:8px;font-size:11px;max-height:300px;overflow:auto"></pre>
    </div>
  </div>
</div>

<style>
.flag-list { display:flex; flex-direction:column; gap:16px; }
.flag-item {
  display:flex;
  align-items:center;
  justify-content:space-between;
  padding:12px 16px;
  background:var(--pink-lightest);
  border-radius:12px;
  border:1px solid var(--pink-light);
}
.flag-info { display:flex; flex-direction:column; gap:2px; }
.flag-info strong { font-size:15px; color:var(--text-dark); }
.flag-desc { font-size:13px; color:var(--text-light); }
</style>

<script>
function toggleCard(el) {
  var body = el.nextElementSibling;
  body.style.display = body.style.display === 'none' ? 'block' : 'none';
}
</script>
<script>
document.querySelectorAll('.flag-toggle').forEach(function(cb) {
  cb.addEventListener('change', function() {
    var key = this.dataset.key;
    var value = this.checked;
    fetch('/admin/api/flags', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ key: key, value: value })
    })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (!data.success) {
          alert('Failed to update flag');
          cb.checked = !cb.checked;
        }
      })
      .catch(function() {
        alert('Network error');
        cb.checked = !cb.checked;
      });
  });
});

document.querySelectorAll('.role-select').forEach(function(sel) {
  sel.addEventListener('change', function() {
    if (!confirm('Change this user\'s role to "' + this.value + '"?')) {
      this.value = this.getAttribute('data-orig') || this.dataset.orig;
      return;
    }
    fetch('/admin/user/' + this.dataset.userId + '/role', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ role: this.value })
    })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          location.reload();
        } else {
          alert(data.error || 'Failed to update role');
        }
      });
  });
  sel.setAttribute('data-orig', sel.value);
});

function deleteUser(id) {
  if (!confirm('Delete this user? This cannot be undone.')) return;
  fetch('/admin/user/' + id + '/delete', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        location.reload();
      } else {
        alert(data.error || 'Failed to delete user');
      }
    });
}

async function runDebug() {
  var el = document.getElementById('debugResult');
  el.textContent = 'Running...\n';
  var lines = [];
  lines.push('User Agent: ' + navigator.userAgent.substring(0, 100));
  lines.push('Standalone: ' + (window.matchMedia('(display-mode: standalone)').matches));
  lines.push('navigator.standalone: ' + (window.navigator.standalone || false));
  lines.push('Protocol: ' + location.protocol);
  lines.push('Notification API: ' + ('Notification' in window));
  if ('Notification' in window) {
    lines.push('Permission: ' + Notification.permission);
    if (Notification.permission === 'default') {
      var p = await Notification.requestPermission();
      lines.push('After request: ' + p);
    }
  }
  lines.push('Service Worker: ' + ('serviceWorker' in navigator));
  if ('serviceWorker' in navigator) {
    try {
      var reg = await navigator.serviceWorker.ready;
      lines.push('SW Active: ' + (reg.active ? 'yes' : 'no'));
      lines.push('PushManager: ' + (typeof reg.pushManager));
      if (reg.pushManager) {
        var sub = await reg.pushManager.getSubscription();
        lines.push('Subscription: ' + (sub ? sub.endpoint.substring(0,60) + '...' : 'none'));
      }
    } catch(e) { lines.push('SW Error: ' + e.message); }
  }
  el.textContent = lines.join('\n');
  document.getElementById('pushDebugContent').textContent = 'Status: ' + (lines[lines.length-1] || 'unknown');
}
async function sendTestPush() {
  var el = document.getElementById('debugResult');
  el.textContent = 'Sending test push...';
  try {
    var r = await fetch('/push/test', { method:'POST' });
    var d = await r.json();
    el.textContent = JSON.stringify(d, null, 2);
  } catch(e) { el.textContent = 'Error: ' + e.message; }
}
</script>
<%- include('partials/footer') %>
