<%- include('partials/header', { title: title, activeNav: 'dashboard' }) %>
<div class="chat-page">
  <div class="chat-sidebar">
    <div class="chat-sidebar-header">
      <h2><i class="fas fa-comments"></i> Chats</h2>
    </div>
    <div class="chat-sidebar-list">
      <% if (friends && friends.length > 0) { %>
        <% friends.forEach(function(f) { %>
          <a href="/chat/<%= f.id %>" class="chat-sidebar-item <%= f.id === friend.id ? 'active' : '' %>">
            <div class="chat-sidebar-avatar">
              <% if (f.profilePic) { %>
                <img src="<%= f.profilePic %>" alt="">
              <% } else { %>
                <div class="avatar-placeholder"><%= (f.displayName || f.username || '?')[0].toUpperCase() %></div>
              <% } %>
              <span class="status-dot offline" data-user-id="<%= f.id %>"></span>
            </div>
            <div class="chat-sidebar-info">
              <span class="chat-sidebar-name"><%= f.displayName || f.username %></span>
              <span class="chat-sidebar-username">@<%= f.username %></span>
            </div>
          </a>
        <% }); %>
      <% } else { %>
        <div class="empty-state">
          <i class="fas fa-user-friends"></i>
          <p>No friends yet</p>
          <a href="/friends" class="btn btn-primary btn-sm">Find Friends</a>
        </div>
      <% } %>
    </div>
  </div>

  <div class="chat-main">
    <div class="chat-header">
      <div class="chat-header-user">
        <% if (friend.profilePic) { %>
          <img src="<%= friend.profilePic %>" alt="">
        <% } else { %>
          <div class="avatar-placeholder"><%= (friend.displayName || friend.username || '?')[0].toUpperCase() %></div>
        <% } %>
        <div class="chat-header-info">
          <h3><%= friend.displayName || friend.username %></h3>
          <span class="chat-status" id="chatStatus">
            <span class="status-dot offline" data-user-id="<%= friend.id %>"></span>
            <span class="status-text">Offline</span>
          </span>
        </div>
      </div>
      <div class="chat-header-actions">
        <a href="/friends" class="btn btn-sm"><i class="fas fa-arrow-left"></i></a>
      </div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(function(msg) { %>
          <% const isMine = msg.sender.id === user.id; %>
          <div class="message <%= isMine ? 'message-sent' : 'message-received' %>" data-message-id="<%= msg.id %>">
            <div class="message-content">
              <% if (msg.repliedTo) { %>
                <div class="reply-quote" data-reply-id="<%= msg.repliedTo.id %>">
                  <div class="reply-sender"><%= msg.repliedTo.sender ? (msg.repliedTo.sender.displayName || msg.repliedTo.sender.username) : 'Unknown' %></div>
                  <div class="reply-preview"><%= msg.repliedTo.fileUrl ? (msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('image/') ? '📷 Photo' : msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('audio/') ? '🎵 Audio' : '📎 File') : (msg.repliedTo.content || '').substring(0, 80) %></div>
                </div>
              <% } %>
              <% if (msg.fileUrl) { %>
                <div class="message-file">
                  <% if (msg.fileType && msg.fileType.startsWith('image/')) { %>
                    <img src="<%= msg.fileUrl %>" alt="<%= msg.fileName || 'Image' %>" class="message-image" onclick="window.open(this.src)">
                  <% } else if (msg.fileType && msg.fileType.startsWith('audio/')) { %>
                    <audio controls src="<%= msg.fileUrl %>"></audio>
                  <% } else { %>
                    <div class="file-attachment">
                      <i class="fas fa-file"></i>
                      <div class="file-info">
                        <a href="<%= msg.fileUrl %>" target="_blank" class="file-name"><%= msg.fileName || 'File' %></a>
                        <% if (msg.fileSize) { %>
                          <span class="file-size"><%= (msg.fileSize / 1024 / 1024).toFixed(1) %> MB</span>
      <% } %>
      <div class="typing-indicator" id="typingIndicator" style="display:none">
        <span></span><span></span><span></span> typing...
      </div>
    </div>
    <div id="replyPreview" class="reply-preview-bar" style="display:none">
      <div class="reply-preview-info">
        <i class="fas fa-reply"></i>
        <span>Replying to <strong id="replyTargetName"></strong></span>
        <span id="replyTargetText" class="reply-target-text"></span>
      </div>
      <button type="button" class="preview-remove" onclick="clearReply()"><i class="fas fa-times"></i></button>
    </div>
    <div class="chat-input">
      <div class="chat-input-actions">
        <button type="button" class="btn-input" id="fileBtn" title="Attach file">
          <i class="fas fa-paperclip"></i>
        </button>
        <input type="file" id="fileInput" accept="image/*,audio/*,video/*,application/*,text/*" style="display:none">
      </div>
      <div class="chat-input-field">
        <textarea id="messageInput" rows="1" placeholder="Type a message..." autocomplete="off"></textarea>
      </div>
      <button type="button" class="btn-send" id="sendBtn" title="Send message" disabled>
        <i class="fas fa-paper-plane"></i>
      </button>
    </div>
    <div id="uploadPreview" class="upload-preview" style="display:none">
      <div class="preview-info">
        <i class="fas fa-file"></i>
        <span id="previewFileName"></span>
      </div>
      <button type="button" class="preview-remove" onclick="clearFilePreview()"><i class="fas fa-times"></i></button>
    </div>
  </div>
</div>

<script>
const socket = window.appSocket || io({ transports: ['websocket', 'polling'] });
const userId = '<%= user.id %>';
const friendId = '<%= friend.id %>';
let selectedFile = null;
let replyToId = null;

const replyPreview = document.getElementById('replyPreview');
const replyTargetName = document.getElementById('replyTargetName');
const replyTargetText = document.getElementById('replyTargetText');

if (socket.connected) {
  socket.emit('user-online', userId);
  socket.emit('join-chat', { userId, friendId });
} else {
  socket.on('connect', () => {
    socket.emit('user-online', userId);
    socket.emit('join-chat', { userId, friendId });
  });
}

const messagesContainer = document.getElementById('chatMessages');
const messageInput = document.getElementById('messageInput');
const sendBtn = document.getElementById('sendBtn');
const fileBtn = document.getElementById('fileBtn');
const fileInput = document.getElementById('fileInput');
const uploadPreview = document.getElementById('uploadPreview');
const previewFileName = document.getElementById('previewFileName');
const typingIndicator = document.getElementById('typingIndicator');
const chatStatus = document.getElementById('chatStatus');

let typingTimeout;

function escapeHtml(text) {
  if (!text) return '';
  var d = document.createElement('div');
  d.appendChild(document.createTextNode(text));
  return d.innerHTML;
}

function scrollToBottom() {
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

scrollToBottom();

messagesContainer.addEventListener('click', function(e) {
  var msg = e.target.closest('.message');
  if (!msg) return;
  if (e.target.closest('.btn-reply') || e.target.closest('.btn-delete-msg') || e.target.closest('.reaction-badge') || e.target.closest('.message-emoji-bar span') || e.target.closest('.reply-quote')) return;
  messagesContainer.querySelectorAll('.message.show-emoji-bar').forEach(function(m) {
    if (m !== msg) m.classList.remove('show-emoji-bar');
  });
  msg.classList.toggle('show-emoji-bar');
});

const unreadIds = Array.from(document.querySelectorAll('.message-received[data-message-id]')).map(el => el.dataset.messageId);
if (unreadIds.length > 0) {
  socket.emit('mark-read', { messageIds: unreadIds });
}

socket.on('new-message', function(msg) {
  const isMine = msg.sender.id === userId;
  const emptyState = messagesContainer.querySelector('.chat-empty');
  if (emptyState) emptyState.remove();

  const div = document.createElement('div');
  div.className = `message ${isMine ? 'message-sent' : 'message-received'}`;
  div.dataset.messageId = msg.id;

  let content = '';
  if (msg.repliedTo) {
    const replySender = msg.repliedTo.sender ? escapeHtml(msg.repliedTo.sender.displayName || msg.repliedTo.sender.username) : 'Unknown';
    const replyText = msg.repliedTo.fileUrl ? (msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('image/') ? '📷 Photo' : msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('audio/') ? '🎵 Audio' : '📎 File') : escapeHtml(msg.repliedTo.content || '').substring(0, 80);
    content += '<div class="reply-quote" data-reply-id="' + escapeHtml(msg.repliedTo.id) + '"><div class="reply-sender">' + replySender + '</div><div class="reply-preview">' + replyText + '</div></div>';
  }
  if (msg.fileUrl) {
    content += '<div class="message-file">';
    if (msg.fileType && msg.fileType.startsWith('image/')) {
      content += '<img src="' + escapeHtml(msg.fileUrl) + '" alt="' + escapeHtml(msg.fileName || 'Image') + '" class="message-image" onclick="window.open(this.src)">';
    } else if (msg.fileType && msg.fileType.startsWith('audio/')) {
      content += '<audio controls src="' + escapeHtml(msg.fileUrl) + '"></audio>';
    } else {
      content += '<div class="file-attachment"><i class="fas fa-file"></i><div class="file-info"><a href="' + escapeHtml(msg.fileUrl) + '" target="_blank" class="file-name">' + escapeHtml(msg.fileName || 'File') + '</a>' + (msg.fileSize ? '<span class="file-size">' + (msg.fileSize / 1024 / 1024).toFixed(1) + ' MB</span>' : '') + '</div><a href="' + escapeHtml(msg.fileUrl) + '" download class="file-download"><i class="fas fa-download"></i></a></div>';
    }
    content += '</div>';
  }
  if (msg.content) {
    content += '<p>' + escapeHtml(msg.content) + '</p>';
  }
  const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  content += '<span class="message-time">' + escapeHtml(time) + '</span>';
  const senderName = escapeHtml(msg.sender.displayName || msg.sender.username).replace(/'/g, "\\'");
  const msgContent = escapeHtml(msg.content || '').replace(/'/g, "\\'").substring(0, 50).replace(/\n/g, ' ');
  content += '<button class="btn-reply" onclick="setReply(\'' + escapeHtml(msg.id) + '\', \'' + senderName + '\', \'' + msgContent + '\')" title="Reply"><i class="fas fa-reply"></i></button>';
  if (isMine) {
    content += '<button class="btn-delete-msg" onclick="deleteMsg(\'' + escapeHtml(msg.id) + '\', \'dm\', \'' + escapeHtml(friendId) + '\')" title="Delete"><i class="fas fa-trash"></i></button>';
  }

  div.innerHTML = '<div class="message-content">' + content + '</div>';
  if (isMine) {
    var statusEl = document.createElement('span');
    statusEl.className = 'message-status' + (msg.read ? ' read' : '');
    statusEl.textContent = msg.read ? 'Read' : 'Sent';
    div.appendChild(statusEl);
  }

  const reactionsHtml = document.createElement('div');
  reactionsHtml.className = 'message-reactions';
  if (msg.reactions && Object.keys(msg.reactions).length > 0) {
    let rHtml = '';
    Object.keys(msg.reactions).forEach(function(emoji) {
      const mine = msg.reactions[emoji].indexOf(userId) !== -1;
      rHtml += '<span class="reaction-badge ' + (mine ? 'mine' : '') + '" onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'' + escapeHtml(emoji) + '\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon(emoji) + ' ' + msg.reactions[emoji].length + '</span>';
    });
    reactionsHtml.innerHTML = rHtml;
    div.appendChild(reactionsHtml);
  }

  const emojiBar = document.createElement('div');
  emojiBar.className = 'message-emoji-bar';
  emojiBar.innerHTML = '<span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'❤️\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon('❤️') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😂\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon('😂') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😮\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon('😮') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😢\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon('😢') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😡\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon('😡') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'👍\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon('👍') + '</span>';
  div.appendChild(emojiBar);

  messagesContainer.appendChild(div);
  scrollToBottom();
  if (!isMine && msg.id) {
    socket.emit('mark-read', { messageIds: [msg.id] });
  }
});

function toggleReaction(messageId, emoji, roomType, roomId) {
  socket.emit('react-to-message', { messageId, emoji, userId, roomType, roomId });
}

function deleteMsg(messageId, roomType, roomId) {
  if (!confirm('Delete this message?')) return;
  socket.emit('delete-message', { messageId, userId, roomType, roomId });
}

socket.on('message-deleted', function(data) {
  var el = document.querySelector('.message[data-message-id="' + data.messageId + '"]');
  if (el) el.remove();
});

function emojiIcon(e) {
  var m = {'❤️':'fa-heart','😂':'fa-face-laugh-squint','😮':'fa-face-surprise','😢':'fa-face-sad-tear','😡':'fa-face-angry','👍':'fa-thumbs-up'};
  return '<i class="fas ' + (m[e]||'fa-heart') + '"></i>';
}

socket.on('user-typing', function(data) {
  if (data.userId !== userId) {
    typingIndicator.style.display = data.isTyping ? 'flex' : 'none';
  }
});

socket.on('message-reacted', function(data) {
  var msgEl = document.querySelector('.message[data-message-id="' + escapeHtml(data.messageId) + '"]');
  if (!msgEl) return;
  var oldReactions = msgEl.querySelector('.message-reactions');
  if (oldReactions) oldReactions.remove();

  var rDiv = document.createElement('div');
  rDiv.className = 'message-reactions';
  if (data.reactions && Object.keys(data.reactions).length > 0) {
    var rHtml = '';
    Object.keys(data.reactions).forEach(function(emoji) {
      var mine = data.reactions[emoji].indexOf(userId) !== -1;
      rHtml += '<span class="reaction-badge ' + (mine ? 'mine' : '') + '" onclick="toggleReaction(\'' + escapeHtml(data.messageId) + '\', \'' + escapeHtml(emoji) + '\', \'dm\', \'' + escapeHtml(friendId) + '\')">' + emojiIcon(emoji) + ' ' + data.reactions[emoji].length + '</span>';
    });
    rDiv.innerHTML = rHtml;
    msgEl.appendChild(rDiv);
  }
});

function setReply(msgId, senderName, msgPreview) {
  replyToId = msgId;
  replyTargetName.textContent = senderName;
  replyTargetText.textContent = msgPreview || 'Reply to message';
  replyPreview.style.display = 'flex';
  messageInput.focus();
}

function clearReply() {
  replyToId = null;
  replyPreview.style.display = 'none';
}

messageInput.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 150) + 'px';
  sendBtn.disabled = !this.value.trim() && !selectedFile;

  socket.emit('typing', { userId, friendId, isTyping: true });
  clearTimeout(typingTimeout);
  typingTimeout = setTimeout(() => {
    socket.emit('typing', { userId, friendId, isTyping: false });
  }, 2000);
});

sendBtn.addEventListener('click', sendMessage);
messageInput.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

fileBtn.addEventListener('click', () => fileInput.click());

fileInput.addEventListener('change', function() {
  const file = this.files[0];
  if (!file) return;
  selectedFile = file;
  previewFileName.textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)`;
  uploadPreview.style.display = 'flex';
  sendBtn.disabled = false;
});

function clearFilePreview() {
  selectedFile = null;
  fileInput.value = '';
  uploadPreview.style.display = 'none';
  sendBtn.disabled = !messageInput.value.trim();
}

function sendMessage() {
  const content = messageInput.value.trim();

  if (!content && !selectedFile) return;

  const replyParam = replyToId || undefined;
  clearReply();

  if (selectedFile) {
    const formData = new FormData();
    formData.append('file', selectedFile);

    fetch('/upload/file', { method: 'POST', body: formData })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          socket.emit('send-message', {
            senderId: userId,
            receiverId: friendId,
            content: content,
            fileUrl: data.fileUrl,
            fileType: data.fileType,
            fileName: data.fileName,
            fileSize: data.fileSize,
            replyToId: replyParam
          });
          clearFilePreview();
        } else {
          showToast(data.error || 'Upload failed', 'error');
        }
      });
    messageInput.value = '';
    messageInput.style.height = 'auto';
    sendBtn.disabled = true;
    return;
  }

  socket.emit('send-message', {
    senderId: userId,
    receiverId: friendId,
    content: content,
    fileUrl: null,
    fileType: null,
    fileName: null,
    fileSize: null,
    replyToId: replyParam
  });

  messageInput.value = '';
  messageInput.style.height = 'auto';
  sendBtn.disabled = true;
  socket.emit('typing', { userId, friendId, isTyping: false });
}

function showToast(msg, type = 'success') {
  const toast = document.createElement('div');
  toast.className = `toast toast-${type}`;
  toast.innerHTML = msg;
  document.body.appendChild(toast);
  setTimeout(() => toast.classList.add('show'), 10);
  setTimeout(() => {
    toast.classList.remove('show');
    setTimeout(() => toast.remove(), 300);
  }, 3000);
}
</script>
<%- include('partials/footer') %>
