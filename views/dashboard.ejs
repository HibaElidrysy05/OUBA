<%- include('partials/header', { title: 'Dashboard - Ouba', activeNav: 'dashboard' }) %>
<div class="dashboard">
  <div class="welcome-section">
    <div class="welcome-card">
      <h1>Hi, <%= user.displayName || user.username %>! 🌸</h1>
      <p>Welcome back to Ouba</p>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="card conversations-card">
      <div class="card-header">
        <h2><i class="fas fa-comments"></i> Recent Chats</h2>
      </div>
      <div class="card-body">
        <% if (conversations && conversations.length > 0) { %>
          <div class="conversation-list">
            <% conversations.forEach(function(conv) { %>
              <a href="/chat/<%= conv.user.id %>" class="conversation-item">
                <div class="conversation-avatar">
                  <% if (conv.user.profilePic) { %>
                    <img src="<%= conv.user.profilePic %>" alt="">
                  <% } else { %>
                    <div class="avatar-placeholder"><%= (conv.user.displayName || conv.user.username || '?')[0].toUpperCase() %></div>
                  <% } %>
                  <span class="status-dot offline" data-user-id="<%= conv.user.id %>"></span>
                </div>
                <div class="conversation-info">
                  <span class="conversation-name"><%= conv.user.displayName || conv.user.username %></span>
                  <span class="conversation-preview">
                    <% if (conv.lastMessage.fileUrl) { %>
                      <i class="fas fa-paperclip"></i> Sent a file
                    <% } else { %>
                      <%= conv.lastMessage.content?.substring(0, 30) || '' %>
                    <% } %>
                  </span>
                </div>
                <div class="conversation-meta">
                  <span class="conversation-time"><%= new Date(conv.lastMessage.createdAt).toLocaleDateString() %></span>
                  <% if (conv.unreadCount > 0) { %>
                    <span class="badge"><%= conv.unreadCount %></span>
                  <% } %>
                </div>
              </a>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <p>No conversations yet</p>
            <p class="sub-text">Add friends to start chatting!</p>
            <a href="/friends" class="btn btn-primary"><i class="fas fa-user-friends"></i> Find Friends</a>
          </div>
        <% } %>
      </div>
    </div>

    <div class="card friends-card">
      <div class="card-header">
        <h2><i class="fas fa-user-friends"></i> Friends</h2>
        <a href="/friends" class="btn btn-sm">View All</a>
      </div>
      <div class="card-body">
        <% if (friends && friends.length > 0) { %>
          <div class="friends-grid">
            <% friends.slice(0, 6).forEach(function(friend) { %>
              <a href="/profile/<%= friend.id %>" class="friend-mini-card">
                <div class="avatar-wrapper">
                  <% if (friend.profilePic) { %>
                    <img src="<%= friend.profilePic %>" alt="">
                  <% } else { %>
                    <div class="avatar-placeholder"><%= (friend.displayName || friend.username || '?')[0].toUpperCase() %></div>
                  <% } %>
                  <span class="status-dot offline" data-user-id="<%= friend.id %>"></span>
                </div>
                <span><%= friend.displayName || friend.username %></span>
              </a>
            <% }); %>
          </div>
          <% if (friends.length > 6) { %>
            <p class="more-text">+<%= friends.length - 6 %> more friends</p>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <i class="fas fa-user-plus"></i>
            <p>No friends yet</p>
            <a href="/friends" class="btn btn-primary"><i class="fas fa-search"></i> Find Friends</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (user.role === 'admin') { %>
  <div class="card" style="margin-top:20px">
    <div class="card-header" onclick="this.nextElementSibling.style.display=this.nextElementSibling.style.display==='none'?'block':'none'" style="cursor:pointer">
      <h2><i class="fas fa-bug"></i> Push Debug</h2>
      <span style="font-size:12px;color:var(--text-light)">tap to toggle</span>
    </div>
    <div class="card-body" id="pushDebugSection" style="display:none">
      <div id="pushDebugContent"></div>
      <button onclick="runDebug()" class="btn btn-sm" style="margin-top:8px">Run Checks</button>
      <button onclick="sendTestPush()" class="btn btn-sm" style="margin-top:8px;margin-left:4px">Test Push</button>
      <pre id="debugResult" style="margin-top:12px;background:#f5f5f5;padding:12px;border-radius:8px;font-size:11px;max-height:300px;overflow:auto"></pre>
    </div>
  </div>
  <script>
  async function runDebug() {
    var el = document.getElementById('debugResult');
    el.textContent = 'Running...\n';
    var lines = [];
    lines.push('User Agent: ' + navigator.userAgent.substring(0, 100));
    lines.push('Standalone: ' + (window.matchMedia('(display-mode: standalone)').matches));
    lines.push('navigator.standalone: ' + (window.navigator.standalone || false));
    lines.push('Protocol: ' + location.protocol);
    lines.push('Notification API: ' + ('Notification' in window));
    if ('Notification' in window) {
      lines.push('Permission: ' + Notification.permission);
      if (Notification.permission === 'default') {
        var p = await Notification.requestPermission();
        lines.push('After request: ' + p);
      }
    }
    lines.push('Service Worker: ' + ('serviceWorker' in navigator));
    if ('serviceWorker' in navigator) {
      try {
        var reg = await navigator.serviceWorker.ready;
        lines.push('SW Active: ' + (reg.active ? 'yes' : 'no'));
        lines.push('PushManager: ' + (typeof reg.pushManager));
        if (reg.pushManager) {
          var sub = await reg.pushManager.getSubscription();
          lines.push('Subscription: ' + (sub ? sub.endpoint.substring(0,60) + '...' : 'none'));
        }
      } catch(e) { lines.push('SW Error: ' + e.message); }
    }
    el.textContent = lines.join('\n');
    document.getElementById('pushDebugContent').textContent = 'Status: ' + (lines[lines.length-1] || 'unknown');
  }
  async function sendTestPush() {
    var el = document.getElementById('debugResult');
    el.textContent = 'Sending test push...';
    try {
      var r = await fetch('/push/test', { method:'POST' });
      var d = await r.json();
      el.textContent = JSON.stringify(d, null, 2);
    } catch(e) { el.textContent = 'Error: ' + e.message; }
  }
  </script>
  <% } %>
</div>
<%- include('partials/footer') %>
