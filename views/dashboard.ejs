<%- include('partials/header', { title: 'Dashboard - Ouba', activeNav: 'dashboard' }) %>
<div class="dashboard">
  <div class="welcome-section">
    <div class="welcome-card">
      <h1>Hi, <%= user.displayName || user.username %>! 🌸</h1>
      <p>Welcome back to Ouba</p>
    </div>
  </div>

  <div class="dashboard-grid">
    <div class="card conversations-card">
      <div class="card-header">
        <h2><i class="fas fa-comments"></i> Recent Chats</h2>
      </div>
      <div class="card-body">
        <% if (conversations && conversations.length > 0) { %>
          <div class="conversation-list">
            <% conversations.forEach(function(conv) { %>
              <a href="/chat/<%= conv.user.id %>" class="conversation-item">
                <div class="conversation-avatar">
                  <% if (conv.user.profilePic) { %>
                    <img src="<%= conv.user.profilePic %>" alt="">
                  <% } else { %>
                    <div class="avatar-placeholder"><%= (conv.user.displayName || conv.user.username || '?')[0].toUpperCase() %></div>
                  <% } %>
                  <span class="status-dot offline" data-user-id="<%= conv.user.id %>"></span>
                </div>
                <div class="conversation-info">
                  <span class="conversation-name"><%= conv.user.displayName || conv.user.username %></span>
                  <span class="conversation-preview">
                    <% if (conv.lastMessage.fileUrl) { %>
                      <i class="fas fa-paperclip"></i> Sent a file
                    <% } else { %>
                      <%= conv.lastMessage.content?.substring(0, 30) || '' %>
                    <% } %>
                  </span>
                </div>
                <div class="conversation-meta">
                  <span class="conversation-time"><%= new Date(conv.lastMessage.createdAt).toLocaleDateString() %></span>
                  <% if (conv.unreadCount > 0) { %>
                    <span class="badge"><%= conv.unreadCount %></span>
                  <% } %>
                </div>
              </a>
            <% }); %>
          </div>
        <% } else { %>
          <div class="empty-state">
            <i class="fas fa-inbox"></i>
            <p>No conversations yet</p>
            <p class="sub-text">Add friends to start chatting!</p>
            <a href="/friends" class="btn btn-primary"><i class="fas fa-user-friends"></i> Find Friends</a>
          </div>
        <% } %>
      </div>
    </div>

    <div class="card friends-card">
      <div class="card-header">
        <h2><i class="fas fa-user-friends"></i> Friends</h2>
        <a href="/friends" class="btn btn-sm">View All</a>
      </div>
      <div class="card-body">
        <% if (friends && friends.length > 0) { %>
          <div class="friends-grid">
            <% friends.slice(0, 6).forEach(function(friend) { %>
              <a href="/profile/<%= friend.id %>" class="friend-mini-card">
                <div class="avatar-wrapper">
                  <% if (friend.profilePic) { %>
                    <img src="<%= friend.profilePic %>" alt="">
                  <% } else { %>
                    <div class="avatar-placeholder"><%= (friend.displayName || friend.username || '?')[0].toUpperCase() %></div>
                  <% } %>
                  <span class="status-dot offline" data-user-id="<%= friend.id %>"></span>
                </div>
                <span><%= friend.displayName || friend.username %></span>
              </a>
            <% }); %>
          </div>
          <% if (friends.length > 6) { %>
            <p class="more-text">+<%= friends.length - 6 %> more friends</p>
          <% } %>
        <% } else { %>
          <div class="empty-state">
            <i class="fas fa-user-plus"></i>
            <p>No friends yet</p>
            <a href="/friends" class="btn btn-primary"><i class="fas fa-search"></i> Find Friends</a>
          </div>
        <% } %>
      </div>
    </div>
  </div>
</div>
<script>
(function() {
  const socket = window.appSocket;
  if (!socket) return;
  let refreshTimer;

  socket.on('new-message-alert', function() {
    clearTimeout(refreshTimer);
    refreshTimer = setTimeout(refreshConversations, 600);
  });

  socket.on('unread-update', function(data) {
    const dmBadge = document.querySelector('.nav-item[href="/"] .badge');
    const groupBadge = document.querySelector('.nav-item[href="/groups"] .badge');
    if (dmBadge) {
      if (data.dmUnread > 0) dmBadge.textContent = data.dmUnread;
      else dmBadge.remove();
    } else if (data.dmUnread > 0) {
      const homeLink = document.querySelector('.nav-item[href="/"]');
      if (homeLink) {
        const b = document.createElement('span');
        b.className = 'badge';
        b.textContent = data.dmUnread;
        homeLink.appendChild(b);
      }
    }
    if (groupBadge) {
      if (data.groupUnread > 0) groupBadge.textContent = data.groupUnread;
      else groupBadge.remove();
    } else if (data.groupUnread > 0) {
      const groupLink = document.querySelector('.nav-item[href="/groups"]');
      if (groupLink) {
        const b = document.createElement('span');
        b.className = 'badge';
        b.textContent = data.groupUnread;
        groupLink.appendChild(b);
      }
    }
  });

  function refreshConversations() {
    fetch('/api/conversations')
      .then(function(r) { return r.json(); })
      .then(function(data) {
        var list = document.querySelector('.conversation-list');
        var emptyState = document.querySelector('.empty-state');
        if (!list) {
          if (data.conversations.length > 0 && emptyState) {
            emptyState.remove();
            var cardBody = document.querySelector('.conversations-card .card-body');
            var newList = document.createElement('div');
            newList.className = 'conversation-list';
            cardBody.appendChild(newList);
            list = newList;
          } else {
            return;
          }
        }
        if (data.conversations.length === 0) {
          var cardBody = list ? list.parentElement : document.querySelector('.conversations-card .card-body');
          if (list) list.remove();
          if (!cardBody.querySelector('.empty-state')) {
            cardBody.innerHTML = '<div class="empty-state"><i class="fas fa-inbox"></i><p>No conversations yet</p><p class="sub-text">Add friends to start chatting!</p><a href="/friends" class="btn btn-primary"><i class="fas fa-user-friends"></i> Find Friends</a></div>';
          }
          return;
        }
        var html = '';
        data.conversations.forEach(function(conv) {
          var name = conv.user.displayName || conv.user.username;
          var initial = (name || '?')[0].toUpperCase();
          var preview = conv.lastMessage.fileUrl
            ? '<i class="fas fa-paperclip"></i> Sent a file'
            : (conv.lastMessage.content ? conv.lastMessage.content.substring(0, 30) || '' : '');
          var time = new Date(conv.lastMessage.createdAt).toLocaleDateString();
          var badgeHtml = conv.unreadCount > 0 ? '<span class="badge">' + conv.unreadCount + '</span>' : '';
          html += '<a href="/chat/' + conv.user.id + '" class="conversation-item">';
          html += '<div class="conversation-avatar">';
          if (conv.user.profilePic) {
            html += '<img src="' + conv.user.profilePic + '" alt="">';
          } else {
            html += '<div class="avatar-placeholder">' + initial + '</div>';
          }
          html += '<span class="status-dot offline" data-user-id="' + conv.user.id + '"></span>';
          html += '</div>';
          html += '<div class="conversation-info">';
          html += '<span class="conversation-name">' + name + '</span>';
          html += '<span class="conversation-preview">' + preview + '</span>';
          html += '</div>';
          html += '<div class="conversation-meta">';
          html += '<span class="conversation-time">' + time + '</span>';
          html += badgeHtml;
          html += '</div>';
          html += '</a>';
        });
        list.innerHTML = html;
      });
  }
})();
</script>
<%- include('partials/footer') %>
