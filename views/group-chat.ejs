<%- include('partials/header', { title: `${group.name} - Ouba`, activeNav: 'groups' }) %>
<div class="chat-page">
  <div class="chat-sidebar">
    <div class="chat-sidebar-header">
      <h2><i class="fas fa-users"></i> Members (<%= members.length %>)</h2>
    </div>
    <div class="chat-sidebar-list">
      <% members.forEach(function(m) { %>
        <div class="chat-sidebar-item">
          <div class="chat-sidebar-avatar">
            <% if (m.user.profilePic) { %>
              <img src="<%= m.user.profilePic %>" alt="">
            <% } else { %>
              <div class="avatar-placeholder" style="width:36px;height:36px;font-size:14px"><%= (m.user.displayName || m.user.username || '?')[0].toUpperCase() %></div>
            <% } %>
            <span class="status-dot offline" data-user-id="<%= m.user.id %>"></span>
          </div>
          <div class="chat-sidebar-info">
            <span class="chat-sidebar-name"><%= m.user.displayName || m.user.username %></span>
            <span class="chat-sidebar-username">
              @<%= m.user.username %>
              <% if (m.role === 'admin') { %><span class="admin-badge">admin</span><% } %>
            </span>
          </div>
        </div>
      <% }); %>
      <% if (members.some(m => m.userId === user.id && m.role === 'admin')) { %>
        <button class="btn btn-sm btn-full" id="addMemberBtn" style="margin-top:8px"><i class="fas fa-user-plus"></i> Add Member</button>
      <% } %>
    </div>
  </div>

  <div class="chat-main">
    <div class="chat-header">
      <div class="chat-header-user">
        <div class="avatar-placeholder" style="width:44px;height:44px;font-size:18px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--white);background:var(--pink);border-radius:50%"><%= group.name[0].toUpperCase() %></div>
        <div class="chat-header-info">
          <h3><%= group.name %></h3>
          <span class="chat-status"><%= members.length %> members</span>
        </div>
      </div>
      <div class="chat-header-actions">
        <a href="/groups" class="btn btn-sm"><i class="fas fa-arrow-left"></i></a>
        <button class="btn btn-sm" id="membersToggleBtn" style="margin-left:4px" title="Members"><i class="fas fa-users"></i> <span class="member-count-label"><%= members.length %></span></button>
        <% if (members.some(m => m.userId === user.id && m.role === 'admin')) { %>
          <button class="btn btn-sm" id="addMemberHeaderBtn" style="margin-left:4px" title="Add member"><i class="fas fa-user-plus"></i></button>
        <% } %>
        <% if (group.createdBy === user.id) { %>
          <button class="btn btn-sm" id="settingsBtn" style="margin-left:4px"><i class="fas fa-cog"></i></button>
        <% } %>
        <button class="btn btn-sm btn-leave" id="leaveGroupBtn" style="margin-left:4px"><i class="fas fa-sign-out-alt"></i></button>
      </div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(function(msg) { %>
          <% const isMine = msg.senderId === user.id; %>
          <div class="message <%= isMine ? 'message-sent' : 'message-received' %>" data-message-id="<%= msg.id %>">
            <div class="message-content">
              <% if (!isMine) { %>
                <div class="group-message-header">
                  <a href="/profile/<%= msg.sender.id %>" class="group-message-avatar">
                    <% if (msg.sender.profilePic) { %>
                      <img src="<%= msg.sender.profilePic %>" alt="" style="width:22px;height:22px;border-radius:50%;object-fit:cover">
                    <% } else { %>
                      <div class="avatar-placeholder" style="width:22px;height:22px;font-size:10px;display:inline-flex"><%= (msg.sender.displayName || msg.sender.username || '?')[0].toUpperCase() %></div>
                    <% } %>
                  </a>
                  <a href="/profile/<%= msg.sender.id %>" class="group-message-sender"><%= msg.sender.displayName || msg.sender.username %></a>
                </div>
              <% } %>
              <% if (msg.repliedTo) { %>
                <div class="reply-quote" data-reply-id="<%= msg.repliedTo.id %>">
                  <div class="reply-sender"><%= msg.repliedTo.sender ? (msg.repliedTo.sender.displayName || msg.repliedTo.sender.username) : 'Unknown' %></div>
                  <div class="reply-preview"><%= msg.repliedTo.fileUrl ? (msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('image/') ? '📷 Photo' : msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('audio/') ? '🎵 Audio' : '📎 File') : (msg.repliedTo.content || '').substring(0, 80) %></div>
                </div>
              <% } %>
              <% if (msg.fileUrl) { %>
                <div class="message-file">
                  <% if (msg.fileType && msg.fileType.startsWith('image/')) { %>
                    <img src="<%= msg.fileUrl %>" alt="<%= msg.fileName || 'Image' %>" class="message-image" onclick="window.open(this.src)">
                  <% } else if (msg.fileType && msg.fileType.startsWith('audio/')) { %>
                    <audio controls src="<%= msg.fileUrl %>"></audio>
                  <% } else { %>
                    <div class="file-attachment">
                      <i class="fas fa-file"></i>
                      <div class="file-info">
                        <a href="<%= msg.fileUrl %>" target="_blank" class="file-name"><%= msg.fileName || 'File' %></a>
                        <% if (msg.fileSize) { %><span class="file-size"><%= (msg.fileSize / 1024 / 1024).toFixed(1) %> MB</span><% } %>
                      </div>
                      <a href="<%= msg.fileUrl %>" download class="file-download"><i class="fas fa-download"></i></a>
                    </div>
                  <% } %>
                </div>
              <% } %>
              <% if (msg.content) { %><p><%- msg.content.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/@(\w+)/g, '<span class="mention" onclick="event.stopPropagation()">@$1</span>') %></p><% } %>
              <span class="message-time"><%= new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
              <button class="btn-reply" onclick="setReply('<%= msg.id %>', '<%= (msg.sender.displayName || msg.sender.username).replace(/'/g, "\\'") %>', '<%= (msg.content || '').replace(/'/g, "\\'").substring(0, 50).replace(/\\n/g, ' ') %>')" title="Reply"><i class="fas fa-reply"></i></button>
              <% if (isMine) { %>
                <button class="btn-delete-msg" onclick="deleteMsg('<%= msg.id %>', 'group', '<%= group.id %>')" title="Delete"><i class="fas fa-trash"></i></button>
              <% } %>
            </div>
            <% if (isMine) { %>
              <span class="message-status <%= msg.read ? 'read' : '' %>"><%= msg.read ? 'Read' : 'Sent' %></span>
            <% } %>
            <% if (msg.reactions && Object.keys(msg.reactions).length > 0) { %>
              <div class="message-reactions">
                <% Object.keys(msg.reactions).forEach(function(emoji) { %>
                  <span class="reaction-badge <%= (msg.reactions[emoji].indexOf(user.id) !== -1) ? 'mine' : '' %>" onclick="toggleReaction('<%= msg.id %>', '<%= emoji %>', 'group', '<%= group.id %>')"><i class="fas <%= { '❤️':'fa-heart','😂':'fa-face-laugh-squint','😮':'fa-face-surprise','😢':'fa-face-sad-tear','😡':'fa-face-angry','👍':'fa-thumbs-up' }[emoji] || 'fa-heart' %>"></i> <%= msg.reactions[emoji].length %></span>
                <% }); %>
              </div>
            <% } %>
            <div class="message-emoji-bar">
              <span onclick="toggleReaction('<%= msg.id %>', '❤️', 'group', '<%= group.id %>')"><i class="fas fa-heart"></i></span>
              <span onclick="toggleReaction('<%= msg.id %>', '😂', 'group', '<%= group.id %>')"><i class="fas fa-face-laugh-squint"></i></span>
              <span onclick="toggleReaction('<%= msg.id %>', '😮', 'group', '<%= group.id %>')"><i class="fas fa-face-surprise"></i></span>
              <span onclick="toggleReaction('<%= msg.id %>', '😢', 'group', '<%= group.id %>')"><i class="fas fa-face-sad-tear"></i></span>
              <span onclick="toggleReaction('<%= msg.id %>', '😡', 'group', '<%= group.id %>')"><i class="fas fa-face-angry"></i></span>
              <span onclick="toggleReaction('<%= msg.id %>', '👍', 'group', '<%= group.id %>')"><i class="fas fa-thumbs-up"></i></span>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state chat-empty">
          <i class="fas fa-comment-dots"></i>
          <p>No messages yet</p>
          <p class="sub-text">Start the conversation!</p>
        </div>
      <% } %>
      <div class="typing-indicator" id="typingIndicator" style="display:none">
        <span></span><span></span><span></span> <strong id="typingName"></strong> typing...
      </div>
    </div>

    <div class="chat-input" style="position:relative">
      <div class="mention-dropdown" id="mentionDropdown"></div>
      <div class="chat-input-actions">
        <button type="button" class="btn-input" id="fileBtn" title="Attach file"><i class="fas fa-paperclip"></i></button>
        <% if (flags && flags.audio_recording !== false) { %>
        <button type="button" class="btn-input" id="micBtn" title="Record audio"><i class="fas fa-microphone"></i></button>
        <% } %>
        <input type="file" id="fileInput" accept="image/*,audio/*,video/*,application/*,text/*" style="display:none">
      </div>
      <div id="recordingBar" class="recording-bar" style="display:none">
        <div class="recording-pulse"></div>
        <span class="recording-timer" id="recordingTimer">0:00</span>
        <button type="button" class="btn-recording-cancel" id="cancelRecording" title="Cancel"><i class="fas fa-times"></i></button>
        <button type="button" class="btn-recording-stop" id="stopRecording" title="Send"><i class="fas fa-check"></i></button>
      </div>
      <div class="chat-input-field">
        <textarea id="messageInput" rows="1" placeholder="Type a message... (@ to mention)" autocomplete="off"></textarea>
      </div>
      <button type="button" class="btn-send" id="sendBtn" title="Send message" disabled><i class="fas fa-paper-plane"></i></button>
    </div>
    <div id="uploadPreview" class="upload-preview" style="display:none">
      <div class="preview-info">
        <i class="fas fa-file"></i>
        <span id="previewFileName"></span>
      </div>
      <button type="button" class="preview-remove" onclick="clearFilePreview()"><i class="fas fa-times"></i></button>
    </div>
    <div id="replyPreview" class="reply-preview-bar" style="display:none">
      <div class="reply-preview-info">
        <i class="fas fa-reply"></i>
        <span>Replying to <strong id="replyTargetName"></strong></span>
        <span id="replyTargetText" class="reply-target-text"></span>
      </div>
      <button type="button" class="preview-remove" onclick="clearReply()"><i class="fas fa-times"></i></button>
    </div>
    <div class="typing-indicator" id="typingIndicator" style="display:none">
      <span></span><span></span><span></span> <strong id="typingName"></strong> typing...
    </div>
  </div>
</div>

<div class="modal-overlay" id="membersModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h2><i class="fas fa-users"></i> Members (<%= members.length %>)</h2>
      <button class="modal-close" onclick="closeMembersModal()">&times;</button>
    </div>
    <div class="modal-body" id="membersModalBody">
      <% members.forEach(function(m) { %>
        <a href="/profile/<%= m.user.id %>" class="search-result-item" style="text-decoration:none;color:inherit">
          <div class="search-result-avatar">
            <% if (m.user.profilePic) { %>
              <img src="<%= m.user.profilePic %>" alt="">
            <% } else { %>
              <div class="avatar-placeholder" style="width:40px;height:40px;font-size:16px"><%= (m.user.displayName || m.user.username || '?')[0].toUpperCase() %></div>
            <% } %>
            <span class="status-dot offline" data-user-id="<%= m.user.id %>"></span>
          </div>
          <div class="search-result-info">
            <span class="search-result-name"><%= m.user.displayName || m.user.username %></span>
            <span class="search-result-username">@<%= m.user.username %><% if (m.role === 'admin') { %> <span class="admin-badge">admin</span><% } %></span>
          </div>
        </a>
      <% }); %>
    </div>
    <div class="modal-footer" style="gap:8px">
      <% if (members.some(m => m.userId === user.id && m.role === 'admin')) { %>
        <button class="btn btn-primary btn-sm" id="addMemberFromModalBtn"><i class="fas fa-user-plus"></i> Add Member</button>
      <% } %>
      <button class="btn btn-sm" onclick="closeMembersModal()">Close</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="addMemberModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h2>Add Member</h2>
      <button class="modal-close" onclick="closeAddMember()">&times;</button>
    </div>
    <div class="modal-body" id="addMemberBody">
      <p>Loading friends...</p>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeAddMember()">Done</button>
    </div>
  </div>
</div>

<div class="modal-overlay" id="groupSettingsModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h2>Group Settings</h2>
      <button class="modal-close" onclick="closeSettings()">&times;</button>
    </div>
    <div class="modal-body">
      <div class="form-group">
        <label for="editGroupName">Group Name</label>
        <input type="text" id="editGroupName" value="<%= group.name %>" maxlength="100">
      </div>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeSettings()">Cancel</button>
      <button class="btn btn-primary" onclick="saveGroupName()">Save</button>
    </div>
  </div>
</div>

<script>
const socket = window.appSocket || io({ transports: ['websocket', 'polling'] });
const userId = '<%= user.id %>';
const groupId = '<%= group.id %>';
const groupMembers = <%- JSON.stringify(members.map(m => ({ id: m.user.id, username: m.user.username, displayName: m.user.displayName, profilePic: m.user.profilePic }))) %>;
let selectedFile = null;
let replyToId = null;

const replyPreview = document.getElementById('replyPreview');
const replyTargetName = document.getElementById('replyTargetName');
const replyTargetText = document.getElementById('replyTargetText');

if (socket.connected) {
  socket.emit('user-online', userId);
  socket.emit('join-group', groupId);
} else {
  socket.on('connect', () => {
    socket.emit('user-online', userId);
    socket.emit('join-group', groupId);
  });
}

const messagesContainer = document.getElementById('chatMessages');
const messageInput = document.getElementById('messageInput');
const sendBtn = document.getElementById('sendBtn');
const fileBtn = document.getElementById('fileBtn');
const fileInput = document.getElementById('fileInput');
const uploadPreview = document.getElementById('uploadPreview');
const previewFileName = document.getElementById('previewFileName');
const typingIndicator = document.getElementById('typingIndicator');

let typingTimeout;
const myName = '<%= (user.displayName || user.username).replace(/'/g, "\\'") %>';
let mentionStartPos = -1;
let mentionQuery = '';
let mentionActive = false;

function escapeHtml(text) {
  if (!text) return '';
  var d = document.createElement('div');
  d.appendChild(document.createTextNode(text));
  return d.innerHTML;
}

function scrollToBottom() {
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

scrollToBottom();

const unreadIds = Array.from(document.querySelectorAll('.message-received[data-message-id]')).map(el => el.dataset.messageId);
if (unreadIds.length > 0) {
  socket.emit('mark-read', { messageIds: unreadIds });
}

messagesContainer.addEventListener('click', function(e) {
  var msg = e.target.closest('.message');
  if (!msg) return;
  if (e.target.closest('.btn-reply') || e.target.closest('.btn-delete-msg') || e.target.closest('.reaction-badge') || e.target.closest('.message-emoji-bar span') || e.target.closest('.reply-quote')) return;
  messagesContainer.querySelectorAll('.message.show-emoji-bar').forEach(function(m) {
    if (m !== msg) m.classList.remove('show-emoji-bar');
  });
  msg.classList.toggle('show-emoji-bar');
});

socket.on('new-group-message', function(msg) {
  const isMine = msg.senderId === userId;
  const emptyState = messagesContainer.querySelector('.chat-empty');
  if (emptyState) emptyState.remove();

  const div = document.createElement('div');
  div.className = 'message ' + (isMine ? 'message-sent' : 'message-received');
  div.dataset.messageId = msg.id;

  let content = '';
  if (!isMine) {
    const senderAvatar = msg.sender.profilePic
      ? '<img src="' + escapeHtml(msg.sender.profilePic) + '" alt="" style="width:22px;height:22px;border-radius:50%;object-fit:cover">'
      : '<div class="avatar-placeholder" style="width:22px;height:22px;font-size:10px;display:inline-flex;align-items:center;justify-content:center">' + escapeHtml((msg.sender.displayName || msg.sender.username || '?')[0].toUpperCase()) + '</div>';
    content += '<div class="group-message-header"><a href="/profile/' + escapeHtml(msg.sender.id) + '" class="group-message-avatar">' + senderAvatar + '</a><a href="/profile/' + escapeHtml(msg.sender.id) + '" class="group-message-sender">' + escapeHtml(msg.sender.displayName || msg.sender.username) + '</a></div>';
  }
  if (msg.repliedTo) {
    const replySender = msg.repliedTo.sender ? escapeHtml(msg.repliedTo.sender.displayName || msg.repliedTo.sender.username) : 'Unknown';
    const replyText = msg.repliedTo.fileUrl ? (msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('image/') ? '📷 Photo' : msg.repliedTo.fileType && msg.repliedTo.fileType.startsWith('audio/') ? '🎵 Audio' : '📎 File') : escapeHtml(msg.repliedTo.content || '').substring(0, 80);
    content += '<div class="reply-quote" data-reply-id="' + escapeHtml(msg.repliedTo.id) + '"><div class="reply-sender">' + replySender + '</div><div class="reply-preview">' + replyText + '</div></div>';
  }
  if (msg.fileUrl) {
    content += '<div class="message-file">';
    if (msg.fileType && msg.fileType.startsWith('image/')) {
      content += '<img src="' + escapeHtml(msg.fileUrl) + '" alt="' + escapeHtml(msg.fileName || 'Image') + '" class="message-image" onclick="window.open(this.src)">';
    } else if (msg.fileType && msg.fileType.startsWith('audio/')) {
      content += '<audio controls src="' + escapeHtml(msg.fileUrl) + '"></audio>';
    } else {
      content += '<div class="file-attachment"><i class="fas fa-file"></i><div class="file-info"><a href="' + escapeHtml(msg.fileUrl) + '" target="_blank" class="file-name">' + escapeHtml(msg.fileName || 'File') + '</a>' + (msg.fileSize ? '<span class="file-size">' + (msg.fileSize / 1024 / 1024).toFixed(1) + ' MB</span>' : '') + '</div><a href="' + escapeHtml(msg.fileUrl) + '" download class="file-download"><i class="fas fa-download"></i></a></div>';
    }
    content += '</div>';
  }
  if (msg.content) content += '<p>' + escapeHtml(msg.content).replace(/@(\w+)/g, '<span class="mention" onclick="event.stopPropagation()">@$1</span>') + '</p>';
  const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  content += '<span class="message-time">' + escapeHtml(time) + '</span>';
  const senderName = escapeHtml(msg.sender.displayName || msg.sender.username).replace(/'/g, "\\'");
  const msgContent = escapeHtml(msg.content || '').replace(/'/g, "\\'").substring(0, 50).replace(/\n/g, ' ');
  content += '<button class="btn-reply" onclick="setReply(\'' + escapeHtml(msg.id) + '\', \'' + senderName + '\', \'' + msgContent + '\')" title="Reply"><i class="fas fa-reply"></i></button>';
  if (isMine) {
    content += '<button class="btn-delete-msg" onclick="deleteMsg(\'' + escapeHtml(msg.id) + '\', \'group\', \'' + escapeHtml(groupId) + '\')" title="Delete"><i class="fas fa-trash"></i></button>';
  }

  div.innerHTML = '<div class="message-content">' + content + '</div>';
  if (isMine) {
    var statusEl = document.createElement('span');
    statusEl.className = 'message-status' + (msg.read ? ' read' : '');
    statusEl.textContent = msg.read ? 'Read' : 'Sent';
    div.appendChild(statusEl);
  }

  const reactionsHtml = document.createElement('div');
  reactionsHtml.className = 'message-reactions';
  if (msg.reactions && Object.keys(msg.reactions).length > 0) {
    let rHtml = '';
    Object.keys(msg.reactions).forEach(function(emoji) {
      const mine = msg.reactions[emoji].indexOf(userId) !== -1;
      rHtml += '<span class="reaction-badge ' + (mine ? 'mine' : '') + '" onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'' + escapeHtml(emoji) + '\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon(emoji) + ' ' + msg.reactions[emoji].length + '</span>';
    });
    reactionsHtml.innerHTML = rHtml;
    div.appendChild(reactionsHtml);
  }

  const emojiBar = document.createElement('div');
  emojiBar.className = 'message-emoji-bar';
  emojiBar.innerHTML = '<span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'❤️\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon('❤️') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😂\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon('😂') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😮\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon('😮') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😢\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon('😢') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'😡\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon('😡') + '</span><span onclick="toggleReaction(\'' + escapeHtml(msg.id) + '\', \'👍\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon('👍') + '</span>';
  div.appendChild(emojiBar);

  messagesContainer.appendChild(div);
  scrollToBottom();
  if (!isMine && msg.id) {
    socket.emit('mark-read', { messageIds: [msg.id] });
  }
});

socket.on('group-typing', function(data) {
  if (data.userId !== userId) {
    document.getElementById('typingName').textContent = data.name || 'Someone';
    typingIndicator.style.display = data.isTyping ? 'flex' : 'none';
    if (data.isTyping) scrollToBottom();
  }
});

function emojiIcon(e) {
  var m = {'❤️':'fa-heart','😂':'fa-face-laugh-squint','😮':'fa-face-surprise','😢':'fa-face-sad-tear','😡':'fa-face-angry','👍':'fa-thumbs-up'};
  return '<i class="fas ' + (m[e]||'fa-heart') + '"></i>';
}

socket.on('message-reacted', function(data) {
  var msgEl = document.querySelector('.message[data-message-id="' + escapeHtml(data.messageId) + '"]');
  if (!msgEl) return;
  var oldReactions = msgEl.querySelector('.message-reactions');
  if (oldReactions) oldReactions.remove();

  var rDiv = document.createElement('div');
  rDiv.className = 'message-reactions';
  if (data.reactions && Object.keys(data.reactions).length > 0) {
    var rHtml = '';
    Object.keys(data.reactions).forEach(function(emoji) {
      var mine = data.reactions[emoji].indexOf(userId) !== -1;
      rHtml += '<span class="reaction-badge ' + (mine ? 'mine' : '') + '" onclick="toggleReaction(\'' + escapeHtml(data.messageId) + '\', \'' + escapeHtml(emoji) + '\', \'group\', \'' + escapeHtml(groupId) + '\')">' + emojiIcon(emoji) + ' ' + data.reactions[emoji].length + '</span>';
    });
    rDiv.innerHTML = rHtml;
    msgEl.appendChild(rDiv);
  }
});

function toggleReaction(messageId, emoji, roomType, roomId) {
  socket.emit('react-to-message', { messageId, emoji, userId, roomType, roomId });
}

function deleteMsg(messageId, roomType, roomId) {
  if (!confirm('Delete this message?')) return;
  socket.emit('delete-message', { messageId, userId, roomType, roomId });
}

socket.on('message-deleted', function(data) {
  var el = document.querySelector('.message[data-message-id="' + data.messageId + '"]');
  if (el) el.remove();
});

function setReply(msgId, senderName, msgPreview) {
  replyToId = msgId;
  replyTargetName.textContent = senderName;
  replyTargetText.textContent = msgPreview || 'Reply to message';
  replyPreview.style.display = 'flex';
  messageInput.focus();
}

function clearReply() {
  replyToId = null;
  replyPreview.style.display = 'none';
}

function showMentionDropdown(query) {
  var dropdown = document.getElementById('mentionDropdown');
  var filtered = groupMembers.filter(function(m) {
    return m.username.toLowerCase().indexOf(query.toLowerCase()) !== -1 ||
           (m.displayName && m.displayName.toLowerCase().indexOf(query.toLowerCase()) !== -1);
  });
  if (filtered.length === 0) {
    dropdown.style.display = 'none';
    return;
  }
  dropdown.innerHTML = filtered.map(function(m) {
    var avatar = m.profilePic
      ? '<img src="' + escapeHtml(m.profilePic) + '" alt="">'
      : '<div class="avatar-placeholder">' + escapeHtml((m.displayName || m.username || '?')[0].toUpperCase()) + '</div>';
    return '<div class="mention-item" data-username="' + escapeHtml(m.username) + '">' + avatar + '<div><div class="mention-name">' + escapeHtml(m.displayName || m.username) + '</div><div class="mention-username">@' + escapeHtml(m.username) + '</div></div></div>';
  }).join('');
  dropdown.style.display = 'block';
  mentionActive = true;
}

function hideMentionDropdown() {
  document.getElementById('mentionDropdown').style.display = 'none';
  mentionStartPos = -1;
  mentionQuery = '';
  mentionActive = false;
}

function selectMention(username) {
  if (mentionStartPos === -1) return;
  var text = messageInput.value;
  var before = text.substring(0, mentionStartPos);
  var after = text.substring(messageInput.selectionStart);
  messageInput.value = before + '@' + username + ' ' + after;
  messageInput.selectionStart = messageInput.selectionEnd = before.length + username.length + 2;
  messageInput.focus();
  messageInput.dispatchEvent(new Event('input'));
  hideMentionDropdown();
}

document.addEventListener('click', function(e) {
  if (!e.target.closest('.mention-dropdown') && !e.target.closest('#messageInput')) {
    hideMentionDropdown();
  }
});

messageInput.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 150) + 'px';
  sendBtn.disabled = !this.value.trim() && !selectedFile;

  var pos = this.selectionStart;
  var text = this.value;
  var atIdx = text.lastIndexOf('@', pos - 1);
  if (atIdx !== -1 && (atIdx === 0 || text[atIdx - 1] === ' ' || text[atIdx - 1] === '\n')) {
    var query = text.substring(atIdx + 1, pos);
    if (/^\w*$/.test(query)) {
      mentionStartPos = atIdx;
      mentionQuery = query;
      showMentionDropdown(query);
    } else {
      hideMentionDropdown();
    }
  } else {
    hideMentionDropdown();
  }

  socket.emit('group-typing', { userId, groupId, name: myName, isTyping: true });
  clearTimeout(typingTimeout);
  typingTimeout = setTimeout(() => {
    socket.emit('group-typing', { userId, groupId, name: myName, isTyping: false });
  }, 2000);
});

sendBtn.addEventListener('click', sendMessage);
messageInput.addEventListener('keydown', function(e) {
  var dropdown = document.getElementById('mentionDropdown');
  if (dropdown.style.display === 'block') {
    var items = dropdown.querySelectorAll('.mention-item');
    var active = dropdown.querySelector('.mention-item.active');
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      var next = active ? active.nextElementSibling : items[0];
      if (active) active.classList.remove('active');
      if (next) next.classList.add('active');
      return;
    }
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      var prev = active ? active.previousElementSibling : items[items.length - 1];
      if (active) active.classList.remove('active');
      if (prev) prev.classList.add('active');
      return;
    }
    if (e.key === 'Enter' || e.key === 'Tab') {
      if (active) {
        e.preventDefault();
        selectMention(active.dataset.username);
        return;
      }
    }
    if (e.key === 'Escape') {
      hideMentionDropdown();
      return;
    }
  }
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

document.getElementById('mentionDropdown').addEventListener('click', function(e) {
  var item = e.target.closest('.mention-item');
  if (item) selectMention(item.dataset.username);
});

fileBtn.addEventListener('click', () => fileInput.click());

fileInput.addEventListener('change', function() {
  const file = this.files[0];
  if (!file) return;
  selectedFile = file;
  previewFileName.textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)`;
  uploadPreview.style.display = 'flex';
  sendBtn.disabled = false;
});

function clearFilePreview() {
  selectedFile = null;
  fileInput.value = '';
  uploadPreview.style.display = 'none';
  sendBtn.disabled = !messageInput.value.trim();
}

function sendMessage() {
  const content = messageInput.value.trim();

  if (!content && !selectedFile) return;

  const replyParam = replyToId || undefined;
  clearReply();

  if (selectedFile) {
    const formData = new FormData();
    formData.append('file', selectedFile);

    fetch('/upload/file', { method: 'POST', body: formData })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          socket.emit('send-group-message', {
            senderId: userId,
            groupId,
            content,
            fileUrl: data.fileUrl,
            fileType: data.fileType,
            fileName: data.fileName,
            fileSize: data.fileSize,
            replyToId: replyParam
          });
          clearFilePreview();
        } else {
          showToast(data.error || 'Upload failed', 'error');
        }
      });
    messageInput.value = '';
    messageInput.style.height = 'auto';
    sendBtn.disabled = true;
    return;
  }

  socket.emit('send-group-message', {
    senderId: userId,
    groupId,
    content,
    fileUrl: null,
    fileType: null,
    fileName: null,
    fileSize: null,
    replyToId: replyParam
  });

  messageInput.value = '';
  messageInput.style.height = 'auto';
  sendBtn.disabled = true;
  socket.emit('group-typing', { userId, groupId, name: myName, isTyping: false });
}

function openAddMember() {
  fetch('/group/' + groupId + '/members')
    .then(r => r.json())
    .then(data => {
      const body = document.getElementById('addMemberBody');
      if (data.addableFriends && data.addableFriends.length > 0) {
        body.innerHTML = data.addableFriends.map(f => `
          <div class="search-result-item" style="cursor:pointer" onclick="addMember('${f.id}')">
            <div class="search-result-avatar">
              ${f.profilePic ? `<img src="${f.profilePic}" alt="">` : `<div class="avatar-placeholder">${(f.displayName || f.username || '?')[0].toUpperCase()}</div>`}
            </div>
            <div class="search-result-info">
              <span class="search-result-name">${f.displayName || f.username}</span>
              <span class="search-result-username">@${f.username}</span>
            </div>
            <div class="search-result-action"><button class="btn btn-primary btn-sm">Add</button></div>
          </div>
        `).join('');
      } else {
        body.innerHTML = '<p class="sub-text">No friends to add. All your friends are already in this group!</p>';
      }
      document.getElementById('addMemberModal').style.display = 'flex';
    });
}

function addMember(friendId) {
  fetch(`/group/${groupId}/add`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId: friendId })
  })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        showToast('Member added!');
        setTimeout(() => location.reload(), 1000);
      } else {
        showToast(data.error || 'Failed to add member', 'error');
      }
    });
}

function closeAddMember() {
  document.getElementById('addMemberModal').style.display = 'none';
}

document.getElementById('settingsBtn')?.addEventListener('click', function() {
  document.getElementById('editGroupName').value = '<%= group.name %>';
  document.getElementById('groupSettingsModal').style.display = 'flex';
});

document.getElementById('addMemberHeaderBtn')?.addEventListener('click', openAddMember);
document.getElementById('addMemberBtn')?.addEventListener('click', openAddMember);

document.getElementById('membersToggleBtn')?.addEventListener('click', function() {
  document.getElementById('membersModal').style.display = 'flex';
});

document.getElementById('addMemberFromModalBtn')?.addEventListener('click', function() {
  closeMembersModal();
  setTimeout(openAddMember, 300);
});

function closeMembersModal() {
  document.getElementById('membersModal').style.display = 'none';
}

function closeSettings() {
  document.getElementById('groupSettingsModal').style.display = 'none';
}

function saveGroupName() {
  const name = document.getElementById('editGroupName').value.trim();
  if (!name) return showToast('Group name is required', 'error');
  fetch('/group/<%= group.id %>/edit', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ name })
  })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        showToast('Group name updated!');
        setTimeout(() => location.reload(), 1000);
      } else {
        showToast(data.error || 'Failed to update', 'error');
      }
    });
}

document.getElementById('leaveGroupBtn')?.addEventListener('click', function() {
  if ('<%= group.createdBy %>' === '<%= user.id %>') {
    if (!confirm('As the creator, deleting the group will remove it for everyone. Continue?')) return;
  } else if (!confirm('Leave this group?')) return;

  fetch('/group/<%= group.id %>/leave', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' }
  })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        window.location.href = '/groups';
      } else {
        showToast(data.error || 'Failed to leave', 'error');
      }
    });
});

function showToast(msg, type) {
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.innerHTML = msg;
  document.body.appendChild(t);
  setTimeout(() => t.classList.add('show'), 10);
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 3000);
}

// Audio recording
let mediaRecorder = null;
let audioChunks = [];
let recordingTimer = null;
let recordingSeconds = 0;
const micBtn = document.getElementById('micBtn');
const recordingBar = document.getElementById('recordingBar');
const recordingTimerEl = document.getElementById('recordingTimer');
const stopRecordingBtn = document.getElementById('stopRecording');
const cancelRecordingBtn = document.getElementById('cancelRecording');

if (micBtn) {
micBtn.addEventListener('click', async function() {
  if (mediaRecorder && mediaRecorder.state === 'recording') return;
  try {
    const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
    mediaRecorder = new MediaRecorder(stream, { mimeType: MediaRecorder.isTypeSupported('audio/webm;codecs=opus') ? 'audio/webm;codecs=opus' : 'audio/webm' });
    audioChunks = [];
    mediaRecorder.ondataavailable = function(e) { if (e.data && e.data.size > 0) audioChunks.push(e.data); };
    mediaRecorder.onstop = function() {
      stream.getTracks().forEach(function(t) { t.stop(); });
      if (audioChunks.length === 0) { showToast('No audio recorded', 'error'); return; }
      var blob = new Blob(audioChunks, { type: mediaRecorder.mimeType || 'audio/webm' });
      var fd = new FormData();
      fd.append('file', blob, 'recording.webm');
      fetch('/upload/file', { method: 'POST', body: fd })
        .then(function(r) { return r.json(); })
        .then(function(data) {
          if (data.success) {
            clearReply();
            socket.emit('send-group-message', {
              senderId: userId,
              groupId,
              content: '',
              fileUrl: data.fileUrl,
              fileType: data.fileType,
              fileName: data.fileName,
              fileSize: data.fileSize,
              replyToId: replyToId || undefined
            });
            replyToId = null;
          } else { showToast(data.error || 'Upload failed', 'error'); }
        })
        .catch(function(err) { showToast('Upload failed: ' + err.message, 'error'); });
    };
    mediaRecorder.start(100); // timeslice 100ms
    micBtn.style.display = 'none';
    recordingBar.style.display = 'flex';
    recordingSeconds = 0;
    updateRecTimer();
    recordingTimer = setInterval(function() { recordingSeconds++; updateRecTimer(); }, 1000);
  } catch (err) { showToast('Microphone access denied', 'error'); }
});

function updateRecTimer() {
  var m = Math.floor(recordingSeconds / 60);
  var s = recordingSeconds % 60;
  recordingTimerEl.textContent = m + ':' + (s < 10 ? '0' : '') + s;
}

stopRecordingBtn.addEventListener('click', function() {
  if (!mediaRecorder || mediaRecorder.state === 'inactive') return;
  clearInterval(recordingTimer);
  mediaRecorder.stop();
  micBtn.style.display = '';
  recordingBar.style.display = 'none';
});

cancelRecordingBtn.addEventListener('click', function() {
  if (!mediaRecorder || mediaRecorder.state === 'inactive') return;
  clearInterval(recordingTimer);
  audioChunks = [];
  mediaRecorder.ondataavailable = null;
  mediaRecorder.onstop = null;
  try { mediaRecorder.stop(); } catch(e) {}
  if (mediaRecorder.stream && mediaRecorder.stream.getTracks) {
    mediaRecorder.stream.getTracks().forEach(function(t) { t.stop(); });
  }
  micBtn.style.display = '';
  recordingBar.style.display = 'none';
});
} // end if (micBtn)
</script>
