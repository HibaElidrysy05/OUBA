<%- include('partials/header', { title: `${group.name} - Ouba`, activeNav: 'groups' }) %>
<div class="chat-page">
  <div class="chat-sidebar">
    <div class="chat-sidebar-header">
      <h2><i class="fas fa-users"></i> Members (<%= members.length %>)</h2>
    </div>
    <div class="chat-sidebar-list">
      <% members.forEach(function(m) { %>
        <div class="chat-sidebar-item">
          <div class="chat-sidebar-avatar">
            <% if (m.user.profilePic) { %>
              <img src="<%= m.user.profilePic %>" alt="">
            <% } else { %>
              <div class="avatar-placeholder" style="width:36px;height:36px;font-size:14px"><%= (m.user.displayName || m.user.username || '?')[0].toUpperCase() %></div>
            <% } %>
            <span class="status-dot offline" data-user-id="<%= m.user.id %>"></span>
          </div>
          <div class="chat-sidebar-info">
            <span class="chat-sidebar-name"><%= m.user.displayName || m.user.username %></span>
            <span class="chat-sidebar-username">
              @<%= m.user.username %>
              <% if (m.role === 'admin') { %><span class="admin-badge">admin</span><% } %>
            </span>
          </div>
        </div>
      <% }); %>
      <% if (members.some(m => m.userId === user.id && m.role === 'admin')) { %>
        <button class="btn btn-sm btn-full" id="addMemberBtn" style="margin-top:8px"><i class="fas fa-user-plus"></i> Add Member</button>
      <% } %>
    </div>
  </div>

  <div class="chat-main">
    <div class="chat-header">
      <div class="chat-header-user">
        <div class="avatar-placeholder" style="width:44px;height:44px;font-size:18px;display:flex;align-items:center;justify-content:center;font-weight:700;color:var(--white);background:var(--pink);border-radius:50%"><%= group.name[0].toUpperCase() %></div>
        <div class="chat-header-info">
          <h3><%= group.name %></h3>
          <span class="chat-status"><%= members.length %> members</span>
        </div>
      </div>
      <div class="chat-header-actions">
        <a href="/groups" class="btn btn-sm"><i class="fas fa-arrow-left"></i></a>
      </div>
    </div>

    <div class="chat-messages" id="chatMessages">
      <% if (messages && messages.length > 0) { %>
        <% messages.forEach(function(msg) { %>
          <% const isMine = msg.senderId === user.id; %>
          <div class="message <%= isMine ? 'message-sent' : 'message-received' %>" data-message-id="<%= msg.id %>">
            <div class="message-content">
              <% if (!isMine) { %>
                <div class="message-sender-name"><%= msg.sender.displayName || msg.sender.username %></div>
              <% } %>
              <% if (msg.fileUrl) { %>
                <div class="message-file">
                  <% if (msg.fileType && msg.fileType.startsWith('image/')) { %>
                    <img src="<%= msg.fileUrl %>" alt="<%= msg.fileName || 'Image' %>" class="message-image" onclick="window.open(this.src)">
                  <% } else if (msg.fileType && msg.fileType.startsWith('audio/')) { %>
                    <audio controls src="<%= msg.fileUrl %>"></audio>
                  <% } else { %>
                    <div class="file-attachment">
                      <i class="fas fa-file"></i>
                      <div class="file-info">
                        <a href="<%= msg.fileUrl %>" target="_blank" class="file-name"><%= msg.fileName || 'File' %></a>
                        <% if (msg.fileSize) { %><span class="file-size"><%= (msg.fileSize / 1024 / 1024).toFixed(1) %> MB</span><% } %>
                      </div>
                      <a href="<%= msg.fileUrl %>" download class="file-download"><i class="fas fa-download"></i></a>
                    </div>
                  <% } %>
                </div>
              <% } %>
              <% if (msg.content) { %><p><%= msg.content %></p><% } %>
              <span class="message-time"><%= new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %></span>
            </div>
          </div>
        <% }); %>
      <% } else { %>
        <div class="empty-state chat-empty">
          <i class="fas fa-comment-dots"></i>
          <p>No messages yet</p>
          <p class="sub-text">Start the conversation!</p>
        </div>
      <% } %>
    </div>

    <div class="chat-input">
      <div class="chat-input-actions">
        <button type="button" class="btn-input" id="fileBtn" title="Attach file"><i class="fas fa-paperclip"></i></button>
        <input type="file" id="fileInput" accept="image/*,audio/*,video/*,application/*,text/*" style="display:none">
      </div>
      <div class="chat-input-field">
        <textarea id="messageInput" rows="1" placeholder="Type a message..." autocomplete="off"></textarea>
      </div>
      <button type="button" class="btn-send" id="sendBtn" title="Send message" disabled><i class="fas fa-paper-plane"></i></button>
    </div>
    <div id="uploadPreview" class="upload-preview" style="display:none">
      <div class="preview-info">
        <i class="fas fa-file"></i>
        <span id="previewFileName"></span>
      </div>
      <button type="button" class="preview-remove" onclick="clearFilePreview()"><i class="fas fa-times"></i></button>
    </div>
    <div class="typing-indicator" id="typingIndicator" style="display:none">
      <span></span><span></span><span></span> typing...
    </div>
  </div>
</div>

<div class="modal-overlay" id="addMemberModal" style="display:none">
  <div class="modal">
    <div class="modal-header">
      <h2>Add Member</h2>
      <button class="modal-close" onclick="closeAddMember()">&times;</button>
    </div>
    <div class="modal-body" id="addMemberBody">
      <p>Loading friends...</p>
    </div>
    <div class="modal-footer">
      <button class="btn" onclick="closeAddMember()">Done</button>
    </div>
  </div>
</div>

<script>
const socket = window.appSocket || io({ transports: ['websocket', 'polling'] });
const userId = '<%= user.id %>';
const groupId = '<%= group.id %>';
let selectedFile = null;

if (socket.connected) {
  socket.emit('user-online', userId);
  socket.emit('join-group', groupId);
} else {
  socket.on('connect', () => {
    socket.emit('user-online', userId);
    socket.emit('join-group', groupId);
  });
}

const messagesContainer = document.getElementById('chatMessages');
const messageInput = document.getElementById('messageInput');
const sendBtn = document.getElementById('sendBtn');
const fileBtn = document.getElementById('fileBtn');
const fileInput = document.getElementById('fileInput');
const uploadPreview = document.getElementById('uploadPreview');
const previewFileName = document.getElementById('previewFileName');
const typingIndicator = document.getElementById('typingIndicator');

let typingTimeout;

function scrollToBottom() {
  messagesContainer.scrollTop = messagesContainer.scrollHeight;
}

scrollToBottom();

socket.on('new-group-message', function(msg) {
  const isMine = msg.senderId === userId;
  const emptyState = messagesContainer.querySelector('.chat-empty');
  if (emptyState) emptyState.remove();

  const div = document.createElement('div');
  div.className = `message ${isMine ? 'message-sent' : 'message-received'}`;
  div.dataset.messageId = msg.id;

  let content = '';
  if (!isMine) {
    content += `<div class="message-sender-name">${msg.sender.displayName || msg.sender.username}</div>`;
  }
  if (msg.fileUrl) {
    content += '<div class="message-file">';
    if (msg.fileType && msg.fileType.startsWith('image/')) {
      content += `<img src="${msg.fileUrl}" alt="${msg.fileName || 'Image'}" class="message-image" onclick="window.open(this.src)">`;
    } else if (msg.fileType && msg.fileType.startsWith('audio/')) {
      content += `<audio controls src="${msg.fileUrl}"></audio>`;
    } else {
      content += `<div class="file-attachment"><i class="fas fa-file"></i><div class="file-info"><a href="${msg.fileUrl}" target="_blank" class="file-name">${msg.fileName || 'File'}</a>${msg.fileSize ? `<span class="file-size">${(msg.fileSize / 1024 / 1024).toFixed(1)} MB</span>` : ''}</div><a href="${msg.fileUrl}" download class="file-download"><i class="fas fa-download"></i></a></div>`;
    }
    content += '</div>';
  }
  if (msg.content) content += `<p>${msg.content}</p>`;
  const time = new Date(msg.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
  content += `<span class="message-time">${time}</span>`;

  div.innerHTML = `<div class="message-content">${content}</div>`;
  messagesContainer.appendChild(div);
  scrollToBottom();
});

socket.on('group-typing', function(data) {
  if (data.userId !== userId) {
    typingIndicator.style.display = data.isTyping ? 'flex' : 'none';
  }
});

messageInput.addEventListener('input', function() {
  this.style.height = 'auto';
  this.style.height = Math.min(this.scrollHeight, 150) + 'px';
  sendBtn.disabled = !this.value.trim() && !selectedFile;

  socket.emit('group-typing', { userId, groupId, isTyping: true });
  clearTimeout(typingTimeout);
  typingTimeout = setTimeout(() => {
    socket.emit('group-typing', { userId, groupId, isTyping: false });
  }, 2000);
});

sendBtn.addEventListener('click', sendMessage);
messageInput.addEventListener('keydown', function(e) {
  if (e.key === 'Enter' && !e.shiftKey) {
    e.preventDefault();
    sendMessage();
  }
});

fileBtn.addEventListener('click', () => fileInput.click());

fileInput.addEventListener('change', function() {
  const file = this.files[0];
  if (!file) return;
  selectedFile = file;
  previewFileName.textContent = `${file.name} (${(file.size / 1024 / 1024).toFixed(1)} MB)`;
  uploadPreview.style.display = 'flex';
  sendBtn.disabled = false;
});

function clearFilePreview() {
  selectedFile = null;
  fileInput.value = '';
  uploadPreview.style.display = 'none';
  sendBtn.disabled = !messageInput.value.trim();
}

function sendMessage() {
  const content = messageInput.value.trim();

  if (!content && !selectedFile) return;

  if (selectedFile) {
    const formData = new FormData();
    formData.append('file', selectedFile);

    fetch('/upload/file', { method: 'POST', body: formData })
      .then(r => r.json())
      .then(data => {
        if (data.success) {
          socket.emit('send-group-message', {
            senderId: userId,
            groupId,
            content,
            fileUrl: data.fileUrl,
            fileType: data.fileType,
            fileName: data.fileName,
            fileSize: data.fileSize
          });
          clearFilePreview();
        } else {
          showToast(data.error || 'Upload failed', 'error');
        }
      });
    messageInput.value = '';
    messageInput.style.height = 'auto';
    sendBtn.disabled = true;
    return;
  }

  socket.emit('send-group-message', {
    senderId: userId,
    groupId,
    content,
    fileUrl: null,
    fileType: null,
    fileName: null,
    fileSize: null
  });

  messageInput.value = '';
  messageInput.style.height = 'auto';
  sendBtn.disabled = true;
  socket.emit('group-typing', { userId, groupId, isTyping: false });
}

document.getElementById('addMemberBtn')?.addEventListener('click', function() {
  fetch(`/group/${groupId}/members`)
    .then(r => r.json())
    .then(data => {
      const body = document.getElementById('addMemberBody');
      if (data.addableFriends && data.addableFriends.length > 0) {
        body.innerHTML = data.addableFriends.map(f => `
          <div class="search-result-item" style="cursor:pointer" onclick="addMember('${f.id}')">
            <div class="search-result-avatar">
              ${f.profilePic ? `<img src="${f.profilePic}" alt="">` : `<div class="avatar-placeholder">${(f.displayName || f.username || '?')[0].toUpperCase()}</div>`}
            </div>
            <div class="search-result-info">
              <span class="search-result-name">${f.displayName || f.username}</span>
              <span class="search-result-username">@${f.username}</span>
            </div>
            <div class="search-result-action"><button class="btn btn-primary btn-sm">Add</button></div>
          </div>
        `).join('');
      } else {
        body.innerHTML = '<p class="sub-text">No friends to add. All your friends are already in this group!</p>';
      }
      document.getElementById('addMemberModal').style.display = 'flex';
    });
});

function addMember(friendId) {
  fetch(`/group/${groupId}/add`, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ userId: friendId })
  })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        showToast('Member added!');
        setTimeout(() => location.reload(), 1000);
      } else {
        showToast(data.error || 'Failed to add member', 'error');
      }
    });
}

function closeAddMember() {
  document.getElementById('addMemberModal').style.display = 'none';
}

function showToast(msg, type) {
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.innerHTML = msg;
  document.body.appendChild(t);
  setTimeout(() => t.classList.add('show'), 10);
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 3000);
}
</script>
<%- include('partials/footer') %>
