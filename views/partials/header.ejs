<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Ouba' %></title>
  <link rel="stylesheet" href="/css/style.css?v=27">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/img/icon.svg?v=2">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="theme-color" content="#FFB6C1">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.js"></script>
  <script src="/js/app.js?v=13"></script>
  <script>
  if ('serviceWorker' in navigator) {
    navigator.serviceWorker.register('/sw.js').catch(() => {});
  }
  function isStandalone() {
    return window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
  }
  function showInstallBanner() {
    if (isStandalone()) return;
    if (localStorage.getItem('pwa-dismissed')) return;
    var banner = document.getElementById('installBanner');
    if (!banner) return;
    setTimeout(function() { banner.style.display = 'flex'; }, 3000);
  }
  if (window.innerWidth < 769) {
    window.addEventListener('load', showInstallBanner);
  }
  function updateNotifBanner() {
    var nb = document.getElementById('notifBanner');
    if (!nb) return;
    if (!('Notification' in window) || !('serviceWorker' in navigator)) { nb.style.display = 'none'; return; }
    if (Notification.permission === 'granted' && localStorage.getItem('push-subscribed') === 'true') {
      nb.style.display = 'none';
    } else {
      nb.style.display = 'flex';
    }
  }
  window.updateNotifBanner = updateNotifBanner;
  updateNotifBanner();
  document.addEventListener('DOMContentLoaded', updateNotifBanner);
  </script>
</head>
<body data-user-id="<%= typeof currentUser !== 'undefined' && currentUser ? currentUser.id : '' %>" data-theme="<%= flags && flags.neutral_theme ? 'neutral' : '' %>">
  <div class="app-container">
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <nav class="sidebar">
      <div class="sidebar-header">
        <a href="/" class="logo">
          <% if (flagsString && flagsString['logo_url']) { %>
            <img src="<%= flagsString['logo_url'] %>" class="logo-img" alt="Ouba">
          <% } else if (flags && flags.logo_text_only) { %>
            <span class="logo-text">Ouba</span>
          <% } else { %>
            <img src="/img/logo.svg" class="logo-svg" alt="Ouba">
          <% } %>
        </a>
      </div>
      <div class="sidebar-user">
        <div class="user-avatar-small">
          <% if (currentUser.profilePic) { %>
            <img src="<%= currentUser.profilePic %>" alt="<%= currentUser.displayName || currentUser.username %>">
          <% } else { %>
            <div class="avatar-placeholder" style="background: #f8a5c2;"><%= (currentUser.displayName || currentUser.username || '?')[0].toUpperCase() %></div>
          <% } %>
        </div>
        <div class="user-info-small">
          <span class="user-name"><%= currentUser.displayName || currentUser.username %></span>
          <span class="user-username">@<%= currentUser.username %></span>
        </div>
      </div>
      <div class="sidebar-nav">
        <a href="/" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'dashboard') ? 'active' : '' %>">
          <i class="fas fa-home"></i>
          <span>Home</span>
        </a>
        <a href="/friends" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'friends') ? 'active' : '' %>">
          <i class="fas fa-user-friends"></i>
          <span>Friends</span>
          <% if (typeof pendingCount !== 'undefined' && pendingCount > 0) { %>
            <span class="badge"><%= pendingCount %></span>
          <% } %>
        </a>
        <a href="/profile" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'profile') ? 'active' : '' %>">
          <i class="fas fa-user"></i>
          <span>Profile</span>
        </a>
        <a href="/map" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'map') ? 'active' : '' %>">
          <i class="fas fa-map-marked-alt"></i>
          <span>Map</span>
        </a>
        <a href="/groups" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'groups') ? 'active' : '' %>">
          <i class="fas fa-users"></i>
          <span>Groups</span>
        </a>
        <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
        <a href="/admin" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'admin') ? 'active' : '' %>">
          <i class="fas fa-shield-alt"></i>
          <span>Admin</span>
        </a>
        <% } %>
        <a href="/logout" class="nav-item mobile-logout">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </div>
      <div class="sidebar-footer">
        <a href="#" class="nav-item" id="notifToggle" onclick="toggleNotifications();return false">
          <i class="fas fa-bell" id="notifIcon"></i>
          <span id="notifText">Enable Notifications</span>
        </a>
        <a href="/logout" class="nav-item">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </div>
    </nav>
    <div class="main-content">
    <div id="notifBanner" style="display:none;background:#FFE4EC;border-radius:12px;padding:12px 16px;margin:0 20px 16px;align-items:center;gap:12px;font-size:14px">
      <span style="flex:1">🔔 Get notified when someone messages you</span>
      <button onclick="toggleNotifications();return false" style="background:#FFB6C1;border:none;padding:8px 20px;border-radius:20px;color:white;font-weight:600;cursor:pointer;white-space:nowrap">Enable Notifications</button>
    </div>
    <% } else { %>
    <div class="main-content full-width">
    <% } %>
