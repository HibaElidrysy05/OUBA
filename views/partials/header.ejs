<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof title !== 'undefined' ? title : 'Ouba' %></title>
  <link rel="stylesheet" href="/css/style.css?v=4">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="https://fonts.googleapis.com/css2?family=Quicksand:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  <link rel="icon" type="image/svg+xml" href="/img/icon.svg">
  <link rel="manifest" href="/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="default">
  <meta name="theme-color" content="#FFB6C1">
  <script src="https://cdnjs.cloudflare.com/ajax/libs/socket.io/4.7.5/socket.io.js"></script>
  <script src="/js/app.js?v=5"></script>
  <script>
  if ('serviceWorker' in navigator) {
    window.addEventListener('load', () => {
      navigator.serviceWorker.register('/sw.js').catch(() => {});
    });
  }
  function isStandalone() {
    return window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone;
  }
  function showInstallBanner() {
    if (isStandalone()) return;
    if (localStorage.getItem('pwa-dismissed')) return;
    var banner = document.getElementById('installBanner');
    if (!banner) return;
    setTimeout(function() { banner.style.display = 'flex'; }, 3000);
  }
  if (window.innerWidth < 769) {
    window.addEventListener('load', showInstallBanner);
  }
  </script>
</head>
<body data-user-id="<%= typeof currentUser !== 'undefined' && currentUser ? currentUser.id : '' %>">
  <div class="app-container">
    <% if (typeof currentUser !== 'undefined' && currentUser) { %>
    <nav class="sidebar">
      <div class="sidebar-header">
        <a href="/" class="logo">
          <span class="logo-icon">🌸</span>
          <span class="logo-text">Ouba</span>
        </a>
      </div>
      <div class="sidebar-user">
        <div class="user-avatar-small">
          <% if (currentUser.profilePic) { %>
            <img src="<%= currentUser.profilePic %>" alt="<%= currentUser.displayName || currentUser.username %>">
          <% } else { %>
            <div class="avatar-placeholder" style="background: #f8a5c2;"><%= (currentUser.displayName || currentUser.username || '?')[0].toUpperCase() %></div>
          <% } %>
        </div>
        <div class="user-info-small">
          <span class="user-name"><%= currentUser.displayName || currentUser.username %></span>
          <span class="user-username">@<%= currentUser.username %></span>
        </div>
      </div>
      <div class="sidebar-nav">
        <a href="/" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'dashboard') ? 'active' : '' %>">
          <i class="fas fa-home"></i>
          <span>Home</span>
        </a>
        <a href="/friends" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'friends') ? 'active' : '' %>">
          <i class="fas fa-user-friends"></i>
          <span>Friends</span>
          <% if (typeof pendingCount !== 'undefined' && pendingCount > 0) { %>
            <span class="badge"><%= pendingCount %></span>
          <% } %>
        </a>
        <a href="/profile" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'profile') ? 'active' : '' %>">
          <i class="fas fa-user"></i>
          <span>Profile</span>
        </a>
        <a href="/groups" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'groups') ? 'active' : '' %>">
          <i class="fas fa-users"></i>
          <span>Groups</span>
        </a>
        <% if (typeof currentUser !== 'undefined' && currentUser && currentUser.role === 'admin') { %>
        <a href="/admin" class="nav-item <%= (typeof activeNav !== 'undefined' && activeNav === 'admin') ? 'active' : '' %>">
          <i class="fas fa-shield-alt"></i>
          <span>Admin</span>
        </a>
        <% } %>
        <a href="/logout" class="nav-item mobile-logout">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </div>
      <div class="sidebar-footer">
        <a href="/logout" class="nav-item">
          <i class="fas fa-sign-out-alt"></i>
          <span>Logout</span>
        </a>
      </div>
    </nav>
    <div class="main-content">
    <% } else { %>
    <div class="main-content full-width">
    <% } %>
