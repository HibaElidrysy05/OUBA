<%- include('partials/header', { title: 'My Profile - Ouba', activeNav: 'profile' }) %>
<div class="profile-page">
  <div class="profile-card">
    <div class="profile-header-section">
      <div class="profile-pic-container">
        <% if (user.profilePic) { %>
          <img src="<%= user.profilePic %>" alt="Profile" id="profilePicPreview">
        <% } else { %>
          <div class="avatar-placeholder large" id="profilePicPreview"><%= (user.displayName || user.username)[0].toUpperCase() %></div>
        <% } %>
        <label for="profilePicInput" class="profile-pic-overlay">
          <i class="fas fa-camera"></i>
        </label>
        <input type="file" id="profilePicInput" accept="image/*" style="display:none">
      </div>
      <h1><%= user.displayName || user.username %></h1>
      <p class="username">@<%= user.username %></p>
      <p class="email"><i class="fas fa-envelope"></i> <%= user.email %></p>
    </div>

    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } %>
    <% if (error) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>

    <form id="profileForm" action="/profile" method="POST" class="profile-form">
      <div class="form-group">
        <label for="username"><i class="fas fa-at"></i> Username</label>
        <input type="text" id="username" name="username" value="<%= user.username %>" placeholder="Your username" pattern="[a-zA-Z0-9_]+" minlength="3" maxlength="20" required>
        <span class="form-hint">Used for finding friends. Letters, numbers, and underscores only.</span>
      </div>
      <div class="form-group">
        <label for="displayName"><i class="fas fa-tag"></i> Display Name</label>
        <input type="text" id="displayName" name="displayName" value="<%= user.displayName || '' %>" placeholder="Your display name">
      </div>
      <div class="form-group">
        <label for="bio"><i class="fas fa-quote-right"></i> Bio</label>
        <textarea id="bio" name="bio" rows="3" placeholder="Tell the world about yourself..." maxlength="200"><%= user.bio || '' %></textarea>
        <span class="char-count"><%= (user.bio || '').length %>/200</span>
      </div>

      <div class="form-group" style="margin-top:4px">
        <label style="display:flex;align-items:center;gap:10px;cursor:pointer">
          <input type="checkbox" id="shareLocation" <%= user.shareLocation ? 'checked' : '' %> style="width:18px;height:18px;accent-color:#FFB6C1;cursor:pointer">
          <span><i class="fas fa-map-marker-alt"></i> Share my location on the map</span>
        </label>
        <span class="form-hint">Your friends will see your real-time location. Only visible to your friends.</span>
      </div>

      <div class="form-divider">
        <span>Change Password (optional)</span>
      </div>

      <div class="form-group">
        <label for="currentPassword"><i class="fas fa-lock"></i> Current Password</label>
        <input type="password" id="currentPassword" name="currentPassword" placeholder="Enter current password">
      </div>
      <div class="form-group">
        <label for="newPassword"><i class="fas fa-key"></i> New Password</label>
        <input type="password" id="newPassword" name="newPassword" placeholder="Enter new password (min 6 chars)" minlength="6">
      </div>

      <button type="submit" class="btn btn-primary btn-full"><i class="fas fa-save"></i> Save Changes</button>
    </form>

    <div class="form-divider" style="margin-top:30px"></div>
    <div style="text-align:center;margin-top:20px">
      <h3 style="color:var(--text-light);margin-bottom:12px;font-size:14px">Danger Zone</h3>
      <button class="btn btn-danger" onclick="deleteAccount()" style="background:#e74c3c;color:white;border:none;padding:10px 24px;border-radius:12px;cursor:pointer;font-size:14px"><i class="fas fa-trash"></i> Delete My Account</button>
    </div>
  </div>
</div>

<script>
function deleteAccount() {
  if (!confirm('Are you sure you want to delete your account? This cannot be undone!')) return;
  const password = prompt('Enter your password to confirm deletion:');
  if (!password) return;
  fetch('/delete-account', {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify({ password })
  })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        window.location.href = '/login';
      } else {
        alert(data.error || 'Failed to delete account');
      }
    });
}

document.getElementById('profilePicInput').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  const formData = new FormData();
  formData.append('profilePic', file);
  fetch('/upload/profile-pic', { method: 'POST', body: formData })
    .then(r => r.json())
    .then(data => {
      if (data.success) {
        const preview = document.getElementById('profilePicPreview');
        preview.outerHTML = `<img src="${data.fileUrl}?t=${Date.now()}" alt="Profile" id="profilePicPreview">`;
        location.reload();
      } else {
        showToast(data.error || 'Upload failed', 'error');
      }
    })
    .catch(() => showToast('Upload failed', 'error'));
});

document.getElementById('bio').addEventListener('input', function() {
  document.querySelector('.char-count').textContent = `${this.value.length}/200`;
});

document.getElementById('shareLocation').addEventListener('change', function() {
  if (this.checked) {
    if (!navigator.geolocation) { alert('Geolocation not supported'); this.checked = false; return; }
    navigator.geolocation.getCurrentPosition(function(pos) {
      fetch('/api/location/update', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ latitude: pos.coords.latitude, longitude: pos.coords.longitude, shareLocation: true })
      }).then(function(r){ return r.json(); }).then(function(d){
        if(!d.success) alert('Failed to save location');
      }).catch(function(){ alert('Failed to save location'); });
    }, function() {
      alert('Could not get your location. Enable location services in Settings.');
      document.getElementById('shareLocation').checked = false;
    });
  } else {
    fetch('/api/location/update', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ shareLocation: false })
    }).catch(function(){});
  }
});

function showToast(msg, type) {
  const t = document.createElement('div');
  t.className = `toast toast-${type}`;
  t.textContent = msg;
  document.body.appendChild(t);
  setTimeout(() => t.classList.add('show'), 10);
  setTimeout(() => { t.classList.remove('show'); setTimeout(() => t.remove(), 300); }, 3000);
}
</script>
<%- include('partials/footer') %>
