<%- include('partials/header', { title: title }) %>
<div class="push-debug" style="max-width:600px;margin:40px auto;padding:0 20px">
  <h2>Push Notification Debug</h2>
  <p><strong>VAPID Public Key:</strong> <code style="word-break:break-all;font-size:11px"><%= vapidKey %></code></p>
  <p><strong>Mode:</strong> <span id="displayMode">checking...</span></p>
  <p><strong>Notification Permission:</strong> <span id="notifPerm">checking...</span></p>
  <p><strong>Service Worker:</strong> <span id="swStatus">checking...</span></p>
  <p><strong>Push Subscriptions on server:</strong> <%= subs.length %></p>
  <% if (subs.length > 0) { %>
    <ul>
      <% subs.forEach(function(s) { %>
        <li style="font-size:12px;margin-bottom:8px">
          <div><strong>ID:</strong> <%= s.id %></div>
          <div><strong>Endpoint:</strong> <code style="word-break:break-all"><%= s.endpoint %></code></div>
          <div><strong>Created:</strong> <%= s.createdAt %></div>
        </li>
      <% }); %>
    </ul>
  <% } else { %>
    <p style="color:red">No subscriptions found.</p>
  <% } %>
  <button onclick="enableNotifs()" style="padding:10px 20px;background:#FFB6C1;border:none;border-radius:8px;color:white;font-weight:600;cursor:pointer">🔔 Enable Notifications</button>
  <button onclick="testPush()" style="padding:10px 20px;background:#7ec8e3;border:none;border-radius:8px;color:white;font-weight:600;cursor:pointer">Send Test Push</button>
  <button onclick="checkBrowser()" style="padding:10px 20px;background:#ddd;border:none;border-radius:8px;margin:8px;cursor:pointer">Check Browser Status</button>
  <pre id="result" style="margin-top:16px;background:#f5f5f5;padding:12px;border-radius:8px;font-size:12px"></pre>
</div>
<script>
async function enableNotifs() {
  var pre = document.getElementById('result');
  pre.textContent = 'Requesting permission...';
  if (!('Notification' in window)) { pre.textContent = 'Notification API not available'; return; }
  var perm = Notification.permission;
  if (perm === 'denied') { pre.textContent = 'Notifications are blocked. Go to Settings > Notifications > Ouba to enable.'; return; }
  if (perm === 'default') {
    perm = await Notification.requestPermission();
    pre.textContent = 'Permission result: ' + perm;
    if (perm !== 'granted') return;
  }
  pre.textContent = 'Permission granted! Subscribing to push...';
  if (!('serviceWorker' in navigator)) { pre.textContent = 'Service Worker not available'; return; }
  try {
    var reg = await navigator.serviceWorker.ready;
    var resp = await fetch('/vapid-public-key');
    var data = await resp.json();
    if (!data.publicKey) { pre.textContent = 'No VAPID public key on server'; return; }
    var sub = await reg.pushManager.subscribe({
      userVisibleOnly: true,
      applicationServerKey: urlBase64ToUint8Array(data.publicKey)
    });
    var saveResp = await fetch('/push-subscribe', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ endpoint: sub.endpoint, keys: sub.toJSON().keys })
    });
    var saveData = await saveResp.json();
    pre.textContent = saveData.success ? 'SUCCESS! Notifications enabled! Close and test.' : 'Save failed: ' + JSON.stringify(saveData);
    location.reload();
  } catch(e) { pre.textContent = 'Error: ' + e.message; }
}
function urlBase64ToUint8Array(base64String) {
  var padding = '='.repeat((4 - base64String.length % 4) % 4);
  var base64 = (base64String + padding).replace(/-/g, '+').replace(/_/g, '/');
  var rawData = window.atob(base64);
  var output = new Uint8Array(rawData.length);
  for (var i = 0; i < rawData.length; ++i) { output[i] = rawData.charCodeAt(i); }
  return output;
}
async function testPush() {
  var pre = document.getElementById('result');
  pre.textContent = 'Sending...';
  try {
    var r = await fetch('/push/test', { method:'POST' });
    var d = await r.json();
    pre.textContent = JSON.stringify(d, null, 2);
  } catch(e) { pre.textContent = 'Error: ' + e.message; }
}
async function checkBrowser() {
  var pre = document.getElementById('result');
  var lines = [];
  lines.push('=== Environment ===');
  lines.push('User agent: ' + navigator.userAgent.substring(0, 80));
  lines.push('Standalone: ' + (window.matchMedia('(display-mode: standalone)').matches || window.navigator.standalone));
  lines.push('Protocol: ' + location.protocol);
  lines.push('=== Notification API ===');
  lines.push('window.Notification: ' + (typeof Notification));
  lines.push('Notification in window: ' + ('Notification' in window));
  try { lines.push('Permission: ' + Notification.permission); } catch(e) { lines.push('Permission error: ' + e.message); }
  lines.push('=== Push API ===');
  lines.push('PushManager in window: ' + ('PushManager' in window));
  lines.push('serviceWorker in navigator: ' + ('serviceWorker' in navigator));
  if ('serviceWorker' in navigator) {
    try {
      var reg = await navigator.serviceWorker.ready;
      lines.push('SW state: ' + (reg.active ? 'active' : 'waiting/installing'));
      lines.push('SW script: ' + (reg.active ? reg.active.scriptURL : 'none'));
      lines.push('PushManager on reg: ' + (typeof reg.pushManager));
      if (reg.pushManager) {
        try {
          var sub = await reg.pushManager.getSubscription();
          lines.push('Subscription: ' + (sub ? 'Yes (' + sub.endpoint.substring(0,50) + '...)' : 'None'));
        } catch(e2) { lines.push('Subscription error: ' + e2.message); }
      }
    } catch(e) { lines.push('SW error: ' + e.message); }
  }
  pre.textContent = lines.join('\n');
}
document.getElementById('displayMode').textContent = (window.matchMedia('(display-mode: standalone)').matches ? 'Standalone PWA (Home Screen)' : 'Browser (Safari)') + (window.navigator.standalone ? ' [navigator.standalone]' : '');
document.getElementById('notifPerm').textContent = ('Notification' in window) ? Notification.permission : 'N/A';
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.ready.then(function(reg) {
    document.getElementById('swStatus').textContent = reg.active ? 'Active' : 'Waiting';
  }).catch(function(e) {
    document.getElementById('swStatus').textContent = 'Error: ' + e.message;
  });
} else {
  document.getElementById('swStatus').textContent = 'Not supported';
}
</script>
<%- include('partials/footer') %>
