<%- include('partials/header', { title: title }) %>
<div class="push-debug" style="max-width:600px;margin:40px auto;padding:0 20px">
  <h2>Push Notification Debug</h2>
  <p><strong>VAPID Public Key:</strong> <code style="word-break:break-all;font-size:11px"><%= vapidKey %></code></p>
  <p><strong>Notification Permission:</strong> <span id="notifPerm">checking...</span></p>
  <p><strong>Service Worker:</strong> <span id="swStatus">checking...</span></p>
  <p><strong>Push Subscriptions on server:</strong> <%= subs.length %></p>
  <% if (subs.length > 0) { %>
    <ul>
      <% subs.forEach(function(s) { %>
        <li style="font-size:12px;margin-bottom:8px">
          <div><strong>ID:</strong> <%= s.id %></div>
          <div><strong>Endpoint:</strong> <code style="word-break:break-all"><%= s.endpoint %></code></div>
          <div><strong>Created:</strong> <%= s.createdAt %></div>
        </li>
      <% }); %>
    </ul>
  <% } else { %>
    <p style="color:red">No subscriptions found. Tap "Enable Notifications" in the sidebar.</p>
  <% } %>
  <button onclick="testPush()" style="padding:10px 20px;background:#FFB6C1;border:none;border-radius:8px;color:white;font-weight:600;cursor:pointer">Send Test Notification</button>
  <button onclick="checkBrowser()" style="padding:10px 20px;background:#ddd;border:none;border-radius:8px;margin-left:8px;cursor:pointer">Check Browser Status</button>
  <pre id="result" style="margin-top:16px;background:#f5f5f5;padding:12px;border-radius:8px;font-size:12px"></pre>
</div>
<script>
async function testPush() {
  var pre = document.getElementById('result');
  pre.textContent = 'Sending...';
  try {
    var r = await fetch('/push/test', { method:'POST' });
    var d = await r.json();
    pre.textContent = JSON.stringify(d, null, 2);
  } catch(e) { pre.textContent = 'Error: ' + e.message; }
}
async function checkBrowser() {
  var pre = document.getElementById('result');
  var lines = [];
  lines.push('Notification: ' + (typeof Notification));
  if ('Notification' in window) {
    lines.push('Permission: ' + Notification.permission);
  }
  if ('serviceWorker' in navigator) {
    try {
      var reg = await navigator.serviceWorker.ready;
      lines.push('SW state: ' + (reg.active ? 'active' : 'inactive'));
      var sub = await reg.pushManager.getSubscription();
      lines.push('Push sub: ' + (sub ? 'Yes (' + sub.endpoint.substring(0,50) + '...)' : 'None'));
    } catch(e) { lines.push('SW error: ' + e.message); }
  } else {
    lines.push('serviceWorker: NOT supported');
  }
  pre.textContent = lines.join('\n');
}
document.getElementById('notifPerm').textContent = ('Notification' in window) ? Notification.permission : 'N/A';
if ('serviceWorker' in navigator) {
  navigator.serviceWorker.ready.then(function(reg) {
    document.getElementById('swStatus').textContent = reg.active ? 'Active' : 'Waiting';
  }).catch(function(e) {
    document.getElementById('swStatus').textContent = 'Error: ' + e.message;
  });
} else {
  document.getElementById('swStatus').textContent = 'Not supported';
}
</script>
<%- include('partials/footer') %>
