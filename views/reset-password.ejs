<%- include('partials/header', { title: 'Reset Password - Ouba' }) %>
<div class="auth-container">
  <div class="auth-card">
    <div class="auth-header">
      <div class="auth-logo">
        <% if (typeof flagsString !== 'undefined' && flagsString && flagsString['logo_url']) { %>
          <img src="<%= flagsString['logo_url'] %>" alt="Ouba" style="height:48px">
        <% } else if (typeof flags !== 'undefined' && flags && flags.logo_text_only) { %>
          <span style="font-size:24px;font-weight:800;color:var(--text-dark);font-family:'Quicksand',sans-serif">Ouba</span>
        <% } else { %>
          <svg width="170" height="48" viewBox="0 0 170 48" alt="Ouba">
            <rect x="2" y="2" width="44" height="44" rx="12" fill="var(--pink)"/>
            <circle cx="24" cy="22" r="11" fill="none" stroke="white" stroke-width="4"/>
            <path d="M13,22 A11,11 0 0,0 35,22" fill="none" stroke="white" stroke-width="4" stroke-linecap="round"/>
            <path d="M30,30 L35,35 L35,30" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
            <circle cx="19" cy="25" r="1.5" fill="white" opacity="0.8"/>
            <circle cx="29" cy="25" r="1.5" fill="white" opacity="0.8"/>
            <text x="56" y="33" font-family="-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif" font-weight="800" font-size="24" fill="var(--text-dark)" letter-spacing="1">Ouba</text>
          </svg>
        <% } %>
      </div>
      <h1>Set New Password</h1>
      <p>Choose a strong password you haven't used before</p>
    </div>
    <% if (error) { %>
      <div class="alert alert-error"><i class="fas fa-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <% if (success) { %>
      <div class="alert alert-success"><i class="fas fa-check-circle"></i> <%= success %></div>
    <% } else { %>
      <form action="/reset-password/<%= token %>" method="POST" class="auth-form">
        <div class="form-group">
          <label for="password"><i class="fas fa-lock"></i> New Password</label>
          <input type="password" id="password" name="password" placeholder="At least 6 characters" minlength="6" required>
        </div>
        <div class="form-group">
          <label for="confirmPassword"><i class="fas fa-check-circle"></i> Confirm Password</label>
          <input type="password" id="confirmPassword" name="confirmPassword" placeholder="Repeat your password" minlength="6" required>
        </div>
        <button type="submit" class="btn btn-primary btn-full">Reset Password <i class="fas fa-arrow-right"></i></button>
      </form>
      <div class="auth-footer">
        <p><a href="/login">Back to Login</a></p>
      </div>
    <% } %>
  </div>
</div>
<%- include('partials/footer') %>
